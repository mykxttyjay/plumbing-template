---
import { Droplet, ShieldCheck, Settings, Flame, Zap, Clock, CircleCheck, ArrowRight, Activity, Wrench, Thermometer } from '@lucide/astro';
import { getLocationText } from "@/config/site"
import WavyDivider from "@/components/sections/WavyDivider.astro"

interface IncludedItem {
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  includedItems: IncludedItem[];
  benefits: string[];
  buttonText?: string;
  buttonHref?: string;
}

const { badge: raw_badge, title: raw_title, description: raw_description, includedItems, benefits, buttonText = "LEARN MORE", buttonHref = "/maintenance-plans" } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;

// Function to get Lucide icon component based on title
function getIconComponentForItem(title: string) {
  const lowerTitle = title.toLowerCase();
  if (lowerTitle.includes('inspection')) return ShieldCheck;
  if (lowerTitle.includes('drain')) return Wrench;
  if (lowerTitle.includes('water heater') || lowerTitle.includes('heater')) return Thermometer;
  if (lowerTitle.includes('priority') || lowerTitle.includes('scheduling')) return Clock;
  if (lowerTitle.includes('discount') || lowerTitle.includes('repair')) return Activity;
  return Settings;
}
---

<section class="relative py-12 md:py-16 overflow-hidden bg-[#091f41]">
  {/* Decorative Background Elements */}
  <div class="absolute top-1/4 -right-20 w-80 h-80 bg-[#40c4eb] rounded-full blur-[120px] opacity-10"></div>
  <div class="absolute bottom-1/4 -left-20 w-60 h-60 bg-accent rounded-full blur-[100px] opacity-10"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-12" data-animate="fade-up">
      {badge && (
        <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-3" style="color: #40c4eb; border: 1.5px solid rgba(64,196,235,0.6); background-color: rgba(64,196,235,0.12);">
          <Droplet class="w-3 h-3 flex-shrink-0" />
          {badge}
        </span>
      )}
      <h2 class="font-extrabold mb-4 text-white" style="font-size: 43px;">{title}</h2>
      <p class="text-white/90 max-w-4xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />
    </div>
    
    <div class="grid lg:grid-cols-2 gap-10 max-w-7xl mx-auto" data-animate-stagger>
      {/* What's Included Card */}
      <div class="bg-white rounded-2xl p-8 md:p-12 shadow-2xl shadow-black/20 flex flex-col relative overflow-hidden group">
        
        <div class="relative z-10 flex-1">
          <div class="mb-8">
            <h3 class="font-black text-[#091f41]" style="font-size: 20px;">What's Included in Our Maintenance Plans?</h3>
          </div>

          <div class="space-y-2">
            {includedItems.map((item) => {
              const Icon = getIconComponentForItem(item.title);
              return (
                <div class="flex items-start gap-5 py-3 pr-4 pl-0 rounded-3xl hover:bg-[#f1fbfe]/40 transition-all duration-300 group/item">
                  <div class="w-12 h-12 rounded-2xl bg-[#f1fbfe] text-[#40c4eb] flex items-center justify-center shrink-0 group-hover/item:bg-[#40c4eb] group-hover/item:text-white transition-all duration-300 mt-1.5">
                    <Icon class="w-6 h-6" />
                  </div>
                  <div>
                    <h4 class="font-bold text-[#091f41] text-lg mb-1">{item.title}</h4>
                    <p class="text-slate-600 text-[16px] leading-relaxed" set:html={item.description} />
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
      
      {/* Why Invest Card */}
      <div class="bg-[#f1fbfe] rounded-2xl p-8 md:p-12 shadow-2xl shadow-black/20 flex flex-col relative overflow-hidden group">
        
        <div class="relative z-10 flex-1 flex flex-col">
          <div class="mb-10">
            <h3 class="text-2xl font-black text-[#091f41]">Why Invest in a Maintenance Plan?</h3>
          </div>

          <div class="space-y-2 mb-12 flex-1">
            {benefits.map((benefit) => (
              <div class="flex items-center gap-4 p-4 rounded-2xl bg-white shadow-sm border border-slate-100 hover:border-[#40c4eb]/30 transition-all duration-300 group/benefit">
                <div class="w-8 h-8 rounded-full bg-[#40c4eb]/10 text-[#40c4eb] flex items-center justify-center shrink-0 group-hover/benefit:bg-[#40c4eb] group-hover/benefit:text-white transition-all duration-300">
                  <CircleCheck class="w-5 h-5" />
                </div>
                <span class="text-[#091f41] font-semibold text-[16px]">{benefit}</span>
              </div>
            ))}
          </div>

          <div class="mt-auto">
            <a href={buttonHref} class="group/btn inline-flex items-center justify-center gap-3 w-full rounded-2xl bg-[#091f41] text-white px-8 py-5 font-bold shadow-xl hover:bg-[#40c4eb] transition-all duration-500 text-lg">
              <span>{buttonText}</span>
              <ArrowRight class="w-5 h-5 group-hover/btn:translate-x-2 transition-transform" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<WavyDivider topColor="#f1fbfe" bottomColor="#091f41" />
