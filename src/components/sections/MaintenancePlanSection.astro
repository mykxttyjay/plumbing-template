---
import { Droplet } from '@lucide/astro';
import { getLocationText } from "@/config/site"
import WavyDivider from "@/components/sections/WavyDivider.astro"

interface IncludedItem {
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  includedItems: IncludedItem[];
  benefits: string[];
  buttonText?: string;
  buttonHref?: string;
}

const { badge: raw_badge, title: raw_title, description: raw_description, includedItems, benefits, buttonText = "LEARN MORE", buttonHref = "/maintenance-plans" } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;

// Function to get icon based on title
function getIconForItem(title: string) {
  const lowerTitle = title.toLowerCase();
  
  if (lowerTitle.includes('inspection')) {
    return '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>';
  } else if (lowerTitle.includes('drain')) {
    return '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>';
  } else if (lowerTitle.includes('water heater') || lowerTitle.includes('heater')) {
    return '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>';
  } else if (lowerTitle.includes('priority') || lowerTitle.includes('scheduling')) {
    return '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
  } else if (lowerTitle.includes('discount') || lowerTitle.includes('repair')) {
    return '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>';
  }
  
  // Default icon
  return '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
}
---

<section class="py-12 md:py-16" style="background-color: #091f41;">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12" data-animate="fade-up">
      {badge && (
        <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-3" style="color: #40c4eb; border: 1.5px solid rgba(64,196,235,0.6); background-color: rgba(64,196,235,0.12);">
          <Droplet class="w-3 h-3 flex-shrink-0" />
          {badge}
        </span>
      )}
      <h2 class="font-extrabold mb-4 text-white" style="font-size: 43px;">{title}</h2>
      <p class="text-white/80 max-w-4xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />
    </div>
    
    <div class="grid lg:grid-cols-2 gap-8 max-w-6xl mx-auto" data-animate-stagger>
      <div class="bg-white rounded-clay py-8 px-6 clay-lift transition-all" style="border: 1.5px solid rgba(64,196,235,0.20);">
        <h3 class="font-extrabold mb-8 text-center text-brand-primary whitespace-nowrap" style="font-size: 22px;">What's Included in Our Maintenance Plans?</h3>
        <div class="grid grid-cols-1 gap-4">
          {includedItems.map((item) => (
            <div class="flex items-start gap-4 p-4 rounded-clay-sm hover:bg-[#f1fbfe] transition-colors duration-200">
              <div class="w-12 h-12 rounded-full bg-accent/15 flex items-center justify-center text-accent shadow-clay-button flex-shrink-0">
                <span set:html={getIconForItem(item.title)}></span>
              </div>
              <div class="flex-1">
                <h4 class="font-extrabold mb-1 text-brand-primary" style="font-size: 17px;">{item.title}</h4>
                <p class="text-gray-600 leading-snug" style="font-size: 15px;" set:html={item.description} />
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <div class="bg-white rounded-clay py-8 px-6 flex flex-col clay-lift transition-all" style="border: 1.5px solid rgba(64,196,235,0.20);">
        <h3 class="font-extrabold mb-8 text-center text-brand-primary whitespace-nowrap" style="font-size: 22px;">Why Invest in a Maintenance Plan?</h3>
        <div class="grid grid-cols-1 gap-2 flex-1">
          {benefits.map((benefit) => (
            <div class="flex items-center gap-4 p-2 rounded-clay-sm hover:bg-brand-secondary/5 transition-colors duration-200">
              <span class="w-10 h-10 rounded-full bg-accent/15 text-accent flex items-center justify-center text-xl shrink-0 font-bold shadow-clay-button">✓</span>
              <span class="text-gray-600 leading-relaxed flex-1" style="font-size: 17px;">{benefit}</span>
            </div>
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href={buttonHref} class="inline-flex items-center justify-center gap-3 rounded-clay-sm bg-highlight text-white px-6 py-2.5 font-semibold shadow-clay-button clay-squish hover:shadow-clay-button-hover transition-all duration-300 text-lg">
            <span>{buttonText}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<WavyDivider topColor="#f1fbfe" bottomColor="#091f41" />
