---
import { Droplet, Star, ChevronLeft, ChevronRight } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface Testimonial {
  name: string;
  initials: string;
  date: string;
  rating: number;
  content: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  testimonials: Testimonial[];
}

const { badge: raw_badge = "Testimonials", title: raw_title, description: raw_description, testimonials: rawTestimonials } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;

const processedTestimonials = rawTestimonials.map(t => ({
  ...t,
  content: getLocationText(t.content),
}));

const featured = processedTestimonials.slice(0, 4);
const carouselItems = processedTestimonials.slice(4);
---

<section class="py-12 md:py-16 bg-[#f1fbfe] overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12" data-animate="fade-up">
      <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-3" style="border: 1.5px solid currentColor; background-color: rgba(64, 196, 235, 0.08);">
        <Droplet class="w-3 h-3 flex-shrink-0" />
        {badge}
      </span>
      <h2 class="font-extrabold mt-2 mb-4" style="font-size: 43px;">{title}</h2>
      {description && <p class="text-brand-primary/80 max-w-4xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />}
    </div>

    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        {/* Left Side: 2x2 Grid of Featured Google Reviews */}
        <div class="lg:col-span-2">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate-stagger>
            {featured.map((testimonial) => (
              <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 font-bold text-lg border border-slate-200">
                      {testimonial.initials}
                    </div>
                    <div>
                      <h3 class="font-bold text-[#091f41] leading-none mb-1">{testimonial.name}</h3>
                      <p class="text-xs text-slate-400">{testimonial.date}</p>
                    </div>
                  </div>
                  <div class="w-6 h-6 shrink-0">
                    <svg viewBox="0 0 24 24" class="w-full h-full">
                      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                  </div>
                </div>
                
                <div class="flex gap-0.5 mb-4">
                  {[...Array(5)].map((_, i) => (
                    <Star class={`w-4 h-4 ${i < testimonial.rating ? 'text-yellow-400 fill-yellow-400' : 'text-slate-200 fill-slate-200'}`} />
                  ))}
                </div>

                <div class="flex-1 mb-4 text-[#091f41] leading-relaxed text-[15px]">
                  <p class="whitespace-pre-wrap line-clamp-6" set:html={testimonial.content} />
                </div>
                
                <div class="text-[11px] font-bold uppercase tracking-wider text-slate-300">
                  Verified Google Review
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Right Side: Carousel of More Google Reviews */}
        <div class="lg:col-span-1 bg-white border border-slate-100 rounded-2xl p-6 shadow-sm flex flex-col h-full min-h-[500px]" data-animate="fade-left">
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-2">
               <div class="w-5 h-5">
                <svg viewBox="0 0 24 24" class="w-full h-full">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
              <h3 class="font-bold text-[#091f41] text-lg">Google Reviews</h3>
            </div>
            <div class="flex gap-1">
              <button id="prev-btn" aria-label="Previous Review" class="w-8 h-8 rounded-full border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#f1fbfe] hover:text-[#40c4eb] transition-all">
                <ChevronLeft class="w-5 h-5" />
              </button>
              <button id="next-btn" aria-label="Next Review" class="w-8 h-8 rounded-full border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#f1fbfe] hover:text-[#40c4eb] transition-all">
                <ChevronRight class="w-5 h-5" />
              </button>
            </div>
          </div>

          <div class="testimonial-carousel-container relative flex-1 overflow-hidden">
            <div id="testimonial-track" class="h-full flex transition-transform duration-500 ease-out">
              {carouselItems.map((testimonial) => (
                <div class="flex-shrink-0 w-full h-full flex flex-col">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 font-bold text-sm border border-slate-200">
                      {testimonial.initials}
                    </div>
                    <div>
                      <h3 class="font-bold text-[#091f41] text-sm leading-none mb-1">{testimonial.name}</h3>
                      <p class="text-[10px] text-slate-400">{testimonial.date}</p>
                    </div>
                  </div>
                  
                  <div class="flex gap-0.5 mb-4">
                    {[...Array(5)].map((_, i) => (
                      <Star class={`w-3.5 h-3.5 ${i < testimonial.rating ? 'text-yellow-400 fill-yellow-400' : 'text-slate-100 fill-slate-100'}`} />
                    ))}
                  </div>

                  <div class="flex-1 text-[#091f41] leading-relaxed text-[15px] italic">
                    <p class="whitespace-pre-wrap" set:html={testimonial.content} />
                  </div>
                  
                  <div class="mt-6 flex items-center justify-between opacity-30 grayscale pointer-events-none">
                     <span class="text-[10px] font-bold">GOOGLE BUSINESS</span>
                     <div class="w-4 h-4">
                        <svg viewBox="0 0 24 24" class="w-full h-full">
                          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="currentColor"/>
                          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="currentColor"/>
                          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="currentColor"/>
                          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="currentColor"/>
                        </svg>
                     </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Dots for carousel */}
          <div class="flex justify-center gap-1.5 mt-8">
            {carouselItems.map((_, i) => (
              <div class={`h-1 rounded-full transition-all duration-300 ${i === 0 ? 'w-6 bg-[#40c4eb]' : 'w-2 bg-slate-100 carousel-dot'}`} data-index={i}></div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .line-clamp-6 {
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  function initTestimonialSlider() {
    const track = document.getElementById('testimonial-track') as HTMLElement;
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    
    if (!track || !prevBtn || !nextBtn) return;

    let currentIndex = 0;
    const items = track.children;
    const totalItems = items.length;

    function updateSlider() {
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
      
      // Update buttons
      prevBtn.style.opacity = currentIndex === 0 ? '0.5' : '1';
      prevBtn.style.pointerEvents = currentIndex === 0 ? 'none' : 'auto';
      nextBtn.style.opacity = currentIndex === totalItems - 1 ? '0.5' : '1';
      nextBtn.style.pointerEvents = currentIndex === totalItems - 1 ? 'none' : 'auto';

      // Update dots
      document.querySelectorAll('[data-index]').forEach(dot => {
        const idx = Number(dot.getAttribute('data-index'));
        if (idx === currentIndex) {
          dot.classList.add('w-6', 'bg-[#40c4eb]');
          dot.classList.remove('w-2', 'bg-slate-100');
        } else {
          dot.classList.remove('w-6', 'bg-[#40c4eb]');
          dot.classList.add('w-2', 'bg-slate-100');
        }
      });
    }

    prevBtn.addEventListener('click', () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateSlider();
      }
    });

    nextBtn.addEventListener('click', () => {
      if (currentIndex < totalItems - 1) {
        currentIndex++;
        updateSlider();
      }
    });

    // Auto-advance
    let interval = setInterval(() => {
      if (currentIndex < totalItems - 1) currentIndex++;
      else currentIndex = 0;
      updateSlider();
    }, 5000);

    // Pause on hover
    track.parentElement?.addEventListener('mouseenter', () => clearInterval(interval));
    track.parentElement?.addEventListener('mouseleave', () => {
       interval = setInterval(() => {
        if (currentIndex < totalItems - 1) currentIndex++;
        else currentIndex = 0;
        updateSlider();
      }, 5000);
    });

    updateSlider();
  }

  document.addEventListener('astro:page-load', initTestimonialSlider);
  initTestimonialSlider();
</script>
