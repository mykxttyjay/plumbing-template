---
import { getLocationText } from "@/config/site"

interface FAQItem {
  question: string;
  answer?: string;
}

interface Props {
  title: string;
  faqs: FAQItem[];
}

const { title: raw_title, faqs: rawFaqs } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : "";
const faqs = rawFaqs.map(faq => ({
  ...faq,
  question: getLocationText(faq.question),
  answer: faq.answer ? getLocationText(faq.answer) : undefined,
}));
---

<section class="py-12 md:py-16 bg-muted/30 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      
      {/* Left Column: Intro & Support */}
      <div data-animate="fade-right">
        <h2 class="font-black mb-6 leading-tight" style="font-size: 43px;">{title}</h2>
        <p class="text-brand-primary/70 mb-10 leading-relaxed" style="font-size: 18px;">
          Have more specific questions about our maintenance plans? Our team is here to help you choose the perfect coverage for your home.
        </p>

        {/* Support Card */}
        <div class="p-8 rounded-[2rem] bg-white border border-brand-primary/5 shadow-xl relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[#40c4eb]/5 rounded-full -mr-16 -mt-16 transition-transform group-hover:scale-110"></div>
          
          <h3 class="text-xl font-black text-brand-primary mb-2">Still have questions?</h3>
          <p class="text-sm text-brand-primary/60 mb-6">Talk to a plumbing expert today for personalized advice.</p>
          
          <a href={`tel:${getLocationText("{phoneRaw}")}`} class="inline-flex items-center gap-3 text-[#40c4eb] font-black hover:gap-5 transition-all">
            <span>Call {getLocationText("{phone}")}</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>

      {/* Right Column: FAQ Accordions */}
      <div class="space-y-4" data-animate-stagger>
        {faqs.map((faq, index) => (
          <details name="faq-accordions" class="group bg-white border border-brand-primary/5 shadow-sm rounded-2xl overflow-hidden transition-all hover:shadow-md" open={index === 0}>
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-[#40c4eb]/5 transition-colors list-none">
              <span class="font-bold text-brand-primary pr-4">{faq.question}</span>
              <span class="shrink-0 w-8 h-8 rounded-full bg-[#40c4eb]/10 text-[#40c4eb] flex items-center justify-center group-open:rotate-180 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </span>
            </summary>
            {faq.answer && (
              <div class="px-6 pb-6 text-brand-primary/70 leading-relaxed" style="font-size: 16px;" set:html={faq.answer} />
            )}
          </details>
        ))}
      </div>

    </div>
  </div>
</section>
