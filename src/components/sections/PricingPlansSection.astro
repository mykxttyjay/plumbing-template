---
import { getLocationText } from "@/config/site"

interface PlanFeature {
  text: string;
}

interface Plan {
  ribbon: string;
  ribbonColor?: "great" | "better" | "best";
  title: string;
  price: string;
  period?: string;
  features: string[];
}

interface Props {
  title: string;
  description: string;
  plans: Plan[];
}

const { title: raw_title, description: raw_description, plans } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;

const ribbonColors = {
  great: "bg-muted text-foreground",
  better: "bg-secondary text-secondary-foreground",
  best: "bg-accent text-accent-foreground"
};
---

<section class="py-12 md:py-16 bg-[#f1fbfe]/50 overflow-hidden">
  <div class="container mx-auto px-4 relative">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="font-extrabold mb-4 max-w-5xl mx-auto text-[#091f41]" style="font-size: 43px;" set:html={title}></h2>
      <p class="text-brand-primary/80 max-w-4xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />
    </div>
    
    <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto items-center" data-animate-stagger>
      {plans.map((plan, index) => {
        const isMiddle = index === 1;
        return (
          <div 
            class={`relative flex flex-col h-full bg-white rounded-[2.5rem] border border-white/50 shadow-[0_20px_50px_rgba(0,0,0,0.05)] transition-all duration-500 hover:translate-y-[-10px] hover:shadow-[0_30px_70px_rgba(9,31,65,0.1)] ${isMiddle ? 'md:scale-105 z-10 border-accent/20 shadow-[0_40px_80px_rgba(64,196,235,0.15)] ring-4 ring-accent/5' : 'md:scale-95 opacity-90'}`}
          >
            {/* Top Ribbon */}
            <div 
              class={`text-center py-4 text-xs font-black uppercase tracking-[0.2em] rounded-t-[2.5rem] ${plan.ribbonColor === 'best' ? 'bg-[#40c4eb] text-white shadow-lg' : 'bg-[#091f41] text-white'}`}
            >
              {plan.ribbon}
            </div>

            <div class="p-8 md:p-10 flex flex-col flex-grow text-center">
              <h3 class="text-2xl font-black text-[#091f41] mb-6 uppercase tracking-tight">{plan.title}</h3>
              
              <div class="mb-10 flex flex-col items-center">
                <div class="flex items-baseline gap-1">
                  <span class="text-5xl font-black text-[#091f41] tracking-tighter">{plan.price}</span>
                  {plan.period && <span class="text-sm font-bold text-[#091f41]/40 uppercase tracking-widest">{plan.period}</span>}
                </div>
              </div>

              <div class="mb-10 text-left">
                <ul class="space-y-5">
                  {plan.features.map((feature) => (
                    <li class="flex items-start gap-4 group">
                      <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[#40c4eb]/10 text-[#40c4eb] flex items-center justify-center transition-colors group-hover:bg-[#40c4eb] group-hover:text-white">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      </div>
                      <span class="text-[16px] font-semibold text-[#091f41]/80 leading-snug">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="mt-auto pt-6">
                <a 
                  href="/contact" 
                  class={`inline-flex items-center justify-center w-full rounded-2xl px-8 py-5 font-black text-sm uppercase tracking-[0.15em] transition-all duration-500 shadow-lg ${isMiddle ? 'bg-[#40c4eb] text-white hover:bg-[#091f41] hover:shadow-[#091f41]/20' : 'bg-[#091f41] text-white hover:bg-[#40c4eb] hover:shadow-[#40c4eb]/20'}`}
                >
                  Get Started
                </a>
              </div>
            </div>

          </div>
        );
      })}
    </div>
  </div>
</section>
