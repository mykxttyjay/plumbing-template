---
import { Droplet } from '@lucide/astro';
import { getLocationText } from "@/config/site"


interface Coupon {
  label: string;
  discount: string;
  description: string;
  expires: string;
}

interface Props {
  coupons: Coupon[];
  variant?: 'default' | 'minimal';
  backgroundColor?: string;
  paddingTop?: boolean;
}

const { coupons, variant = 'default', backgroundColor = '#091f41', paddingTop = true } = Astro.props;
const isMinimal = variant === 'minimal';
const isDarkBackground = backgroundColor === '#091f41';
const textColorClass = isDarkBackground ? 'text-white' : 'text-brand-primary';
const subtextColorClass = isDarkBackground ? 'text-white/70' : 'text-brand-primary/70';
---

<section class={`pb-12 md:pb-16 ${paddingTop ? 'pt-12 md:pt-16' : 'pt-0'}`} style={`background-color: ${backgroundColor};`}>
  <div class="container mx-auto px-4">
    <div class="text-center mb-16" data-animate="fade-up">
      {!isMinimal && (
        <div class="flex justify-center mb-6">
          <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide" style="color: #40c4eb; border: 1.5px solid rgba(64, 196, 235, 0.4); background-color: rgba(64, 196, 235, 0.15);">
            <Droplet class="w-4 h-4 flex-shrink-0" />
            LIMITED TIME OFFERS
          </span>
        </div>
      )}
      <h2 class={`font-black ${textColorClass} leading-tight`} style="font-size: 43px;">
        {isMinimal ? 'Special Discounts & Promotions' : 'Save Big on Plumbing Services'}
      </h2>
      {isMinimal && (
        <p class={`${subtextColorClass} mt-6 max-w-2xl mx-auto leading-relaxed`} style="font-size: 18px;">
          Check this page regularly for the latest special offers and promotions from {getLocationText("{fullName}")}. We also offer financing.
        </p>
      )}
    </div>
    <div class={isMinimal ? 'grid sm:grid-cols-2 lg:grid-cols-3 gap-8' : 'grid md:grid-cols-3 gap-8'} data-animate-stagger>
      {coupons.map((coupon, index) => (
        isMinimal ? (
          <div class="relative group bg-white border-2 border-dashed rounded-[2rem] p-8 transition-all duration-500 hover:-translate-y-2 hover:shadow-xl overflow-hidden" style="border-color: rgba(64, 196, 235, 0.4);">
            {/* Punch hole effects */}
            <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full border-2 border-dashed border-r-0" style={`background-color: ${backgroundColor}; border-color: rgba(64, 196, 235, 0.4);`}></div>
            <div class="absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full border-2 border-dashed border-l-0" style={`background-color: ${backgroundColor}; border-color: rgba(64, 196, 235, 0.4);`}></div>
            
            <div class="flex items-center justify-between gap-3 mb-6">
              <span class="text-xs font-black px-3 py-1 rounded-full uppercase tracking-widest bg-[#40c4eb]/10 text-[#40c4eb]">
                {coupon.label}
              </span>
              <span class="text-[11px] font-bold text-brand-primary/40 uppercase tracking-wider">
                Expires: {coupon.expires}
              </span>
            </div>
            
            <div class="text-3xl md:text-4xl font-black text-[#40c4eb] mb-4 group-hover:scale-105 transition-transform duration-500">
              {coupon.discount}
            </div>
            
            <p class="text-brand-primary/70 font-medium leading-relaxed" style="font-size: 15px;" set:html={coupon.description} />
            
            <div class="mt-8 pt-6 border-t border-dashed" style="border-color: rgba(64, 196, 235, 0.2);">
              <div class="flex items-center justify-between group/btn cursor-pointer">
                <span class="text-xs font-black text-brand-primary uppercase tracking-widest">Redeem Offer</span>
                <div class="w-8 h-8 rounded-full bg-brand-primary/5 flex items-center justify-center transition-all duration-300 group-hover/btn:bg-[#40c4eb] group-hover/btn:text-white text-brand-primary">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        ) : index === 0 ? (
          // CARD 1: Ribbon corner, cream background, scalloped bottom, accent button section
          <div class="coupon-card-1 group relative transition-all duration-300 overflow-visible rounded-xl">
            {/* Cream Content Section */}
            <div class="bg-amber-50 px-8 pt-10 pb-6 text-center relative rounded-t-2xl">
              <span class="inline-block bg-accent/20 text-accent text-sm font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4" style="background-color: rgba(64, 196, 235, 0.2); color: #40c4eb;">
                DISCOUNT
              </span>
              <div class="text-7xl md:text-8xl font-black text-gray-800 mb-2 group-hover:scale-105 transition-transform duration-300 leading-none">
                {coupon.discount}
              </div>
              <p class="text-base text-gray-600 font-medium tracking-wide mb-4" set:html={coupon.description} />
              <p class="text-xs text-gray-600 font-medium mb-6">Offer Expires: {coupon.expires}</p>
              
              {/* Coupon Notches - positioned at the middle of the border between cream and blue */}
              <div class="absolute left-0 right-0 flex justify-between" style="bottom: -16px; z-index: 5;">
                <div class="w-8 h-8 rounded-full" style={`background-color: ${backgroundColor}; margin-left: -16px;`}></div>
                <div class="w-8 h-8 rounded-full" style={`background-color: ${backgroundColor}; margin-right: -16px;`}></div>
              </div>
            </div>
            
            {/* Accent Button Section */}
            <div class="px-6 py-6 text-center" style="background-color: #40c4eb;">
              <button class="bg-white text-accent font-bold py-3 px-10 rounded-full transition-colors duration-200 text-sm uppercase tracking-wide cursor-pointer" style="color: #40c4eb;" onmouseover="this.style.backgroundColor='#091f41'; this.style.color='white';" onmouseout="this.style.backgroundColor='white'; this.style.color='#40c4eb';">
                Redeem & Save Today
              </button>
            </div>
            
            {/* Wavy Edge at bottom - Sine wave */}
            <div class="h-3" style={`background-color: #40c4eb; background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 1200 60%22 preserveAspectRatio=%22none%22><path d=%22M0,30 Q75,0 150,30 T300,30 T450,30 T600,30 T750,30 T900,30 T1050,30 T1200,30 L1200,60 L0,60 Z%22 fill=%22${backgroundColor.replace('#', '%23')}%22/></svg>'); background-repeat: repeat-x; background-size: 150px 100%;`}></div>
          </div>
        ) : index === 1 ? (
          // CARD 2: Accent border frame, white background, accent button section
          <div class="coupon-card-2 group relative transition-all duration-300 overflow-hidden rounded-xl" style="border: 8px solid #40c4eb;">
            {/* White Content Section */}
            <div class="bg-white px-6 pt-12 pb-8 text-center">
              <span class="inline-block bg-accent/20 text-accent text-sm font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4" style="background-color: rgba(64, 196, 235, 0.2); color: #40c4eb;">
                {coupon.label}
              </span>
              <div class="text-7xl md:text-8xl font-black text-gray-800 mb-3 group-hover:scale-105 transition-transform duration-300">
                {coupon.discount}
              </div>
              <p class="text-base text-gray-600 font-medium mb-4" set:html={coupon.description} />
              <p class="text-xs text-gray-600 font-medium">Offer Expires: {coupon.expires}</p>
            </div>
            
            {/* Accent Button Section */}
            <div class="px-6 py-6 text-center" style="background-color: #40c4eb;">
              <button class="bg-white text-accent font-bold py-3 px-10 rounded-full transition-colors duration-200 text-sm uppercase tracking-wide cursor-pointer" style="color: #40c4eb;" onmouseover="this.style.backgroundColor='#091f41'; this.style.color='white';" onmouseout="this.style.backgroundColor='white'; this.style.color='#40c4eb';">
                Redeem & Save Today
              </button>
            </div>
          </div>
        ) : (
          // CARD 3: Cream background, scalloped edges top and bottom, accent button section
          <div class="coupon-card-3 group relative transition-all duration-300 overflow-hidden rounded-xl">
            {/* Cream Content Section */}
            <div class="bg-amber-50 px-6 pt-10 pb-2 text-center relative">
              <span class="inline-block bg-accent/20 text-accent text-sm font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4" style="background-color: rgba(64, 196, 235, 0.2); color: #40c4eb;">
                {coupon.label}
              </span>
              <div class="text-7xl md:text-8xl font-black text-gray-800 mb-3 group-hover:scale-105 transition-transform duration-300">
                {coupon.discount}
              </div>
              <p class="text-base text-gray-600 font-medium mb-4" set:html={coupon.description} />
              <p class="text-xs text-gray-600 font-medium mb-8">Offer Expires: {coupon.expires}</p>
              
              {/* Coupon Notches - positioned at the middle of the border between cream and blue */}
              <div class="absolute left-0 right-0 flex justify-between" style="bottom: -16px; z-index: 5;">
                <div class="w-8 h-8 rounded-full" style={`background-color: ${backgroundColor}; margin-left: -16px;`}></div>
                <div class="w-8 h-8 rounded-full" style={`background-color: ${backgroundColor}; margin-right: -16px;`}></div>
              </div>
            </div>
            
            {/* Wavy Edge in middle - Sine wave */}
            <div class="h-2" style="background-color: #fffbeb; background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 1200 60%22 preserveAspectRatio=%22none%22><path d=%22M0,30 Q75,0 150,30 T300,30 T450,30 T600,30 T750,30 T900,30 T1050,30 T1200,30 L1200,60 L0,60 Z%22 fill=%22%2340c4eb%22/></svg>'); background-repeat: repeat-x; background-size: 150px 100%;"></div>
            
            {/* Accent Button Section */}
            <div class="px-6 py-6 text-center rounded-b-xl" style="background-color: #40c4eb;">
              <button class="bg-white text-accent font-bold py-3 px-10 rounded-full transition-colors duration-200 text-sm uppercase tracking-wide cursor-pointer" style="color: #40c4eb;" onmouseover="this.style.backgroundColor='#091f41'; this.style.color='white';" onmouseout="this.style.backgroundColor='white'; this.style.color='#40c4eb';">
                Redeem & Save Today
              </button>
            </div>
          </div>
        )
      ))}
    </div>
  </div>
</section>

<style>
</style>
