---
import { Flame, Scissors, Clock } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface Coupon {
  label: string;
  discount: string;
  description: string;
  expires: string;
}

interface Props {
  coupons: Coupon[];
  variant?: 'default' | 'minimal';
}

const { coupons, variant = 'default' } = Astro.props;
const isMinimal = variant === 'minimal';
---

<section class="py-16 md:py-24 bg-brand-tertiary/50 dark:bg-brand-primary/20">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10" data-animate="fade-up">
      {!isMinimal && (
        <span class="inline-flex items-center gap-2 bg-accent text-accent-foreground text-sm font-bold px-5 py-2 rounded-full mb-4 shadow-md shadow-accent/30">
          <Flame class="w-4 h-4" />
          LIMITED TIME OFFERS
        </span>
      )}
      <h2 class="text-3xl md:text-4xl font-bold text-primary">
        {isMinimal ? 'Special Discounts & Promotions' : 'Save Big on Plumbing Services'}
      </h2>
      {isMinimal && (
        <p class="text-muted-foreground mt-3 max-w-2xl mx-auto">
          Check this page regularly for the latest special offers and promotions from {getLocationText("{fullName}")}. We also offer financing.
        </p>
      )}
    </div>
    <div class={isMinimal ? 'grid sm:grid-cols-2 lg:grid-cols-3 gap-4' : 'grid md:grid-cols-3 gap-6'} data-animate-stagger>
      {coupons.map((coupon) => (
        isMinimal ? (
          <div class="bg-card border border-border rounded-lg p-5 hover:border-accent/50 transition-colors">
            <div class="flex items-start justify-between gap-3 mb-3">
              <span class="text-xs font-semibold text-accent uppercase tracking-wide">
                {coupon.label}
              </span>
              <span class="text-xs text-muted-foreground whitespace-nowrap">
                Expires: {coupon.expires}
              </span>
            </div>
            <div class="text-2xl md:text-3xl font-bold text-accent mb-2">
              {coupon.discount}
            </div>
            <p class="text-sm text-muted-foreground" set:html={coupon.description} />
          </div>
        ) : (
          <div class="coupon-card group relative bg-card border-2 border-dashed border-accent/40 rounded-lg p-6 text-center shadow-lg hover:shadow-2xl hover:border-highlight transition-all duration-300 overflow-hidden hover:-translate-y-1">
            <div class="absolute -right-8 top-4 bg-accent text-accent-foreground text-xs font-bold py-1 px-10 rotate-45 shadow-md">
              SAVE
            </div>
            <div class="absolute -left-1 bottom-[52px] text-accent">
              <Scissors class="w-5 h-5" />
            </div>
            <span class="inline-block bg-accent/10 text-accent text-sm font-bold px-3 py-1 rounded-full uppercase tracking-wide">
              {coupon.label}
            </span>
            <h3 class="text-lg font-bold mt-3 mb-2 text-brand-secondary">Special Deal</h3>
            <p class="text-sm text-muted-foreground mb-3">Redeem & Save Today</p>
            <div class="text-5xl md:text-6xl font-black text-accent mb-4 group-hover:scale-110 transition-transform duration-300">
              {coupon.discount}
            </div>
            <p class="text-sm text-muted-foreground mb-4" set:html={coupon.description} />
            <div class="border-t border-dashed border-accent/30 pt-3 mt-3">
              <p class="inline-flex items-center gap-1 text-xs text-accent font-semibold">
                <Clock class="w-3 h-3" />
                Offer Expires: {coupon.expires}
              </p>
            </div>
          </div>
        )
      ))}
    </div>
  </div>
</section>

<style>
  .coupon-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--accent), var(--brand-highlight, #45f9ff), var(--accent));
  }
</style>
