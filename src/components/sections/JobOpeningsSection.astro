---
import { getLocationText } from "@/config/site"
import { Droplet, Briefcase, ChevronRight } from '@lucide/astro';

interface JobOpening {
  title: string;
  type?: string;
  responsibilities: string;
  buttonText?: string;
  buttonHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  jobs: JobOpening[];
  introTitle?: string;
  introDescription?: string;
}

const { badge: raw_badge, title: raw_title, description: raw_description, jobs, introTitle: raw_introTitle, introDescription: raw_introDescription } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const introTitle = raw_introTitle ? getLocationText(raw_introTitle) : raw_introTitle;
const introDescription = raw_introDescription ? getLocationText(raw_introDescription) : raw_introDescription;
---

<section class="py-12 md:py-16 bg-white relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-12" data-animate="fade-up">
      <h2 class="font-black mb-6 leading-tight" style="font-size: 40px;">{introTitle || title}</h2>
      {(introDescription || description) && (
        <p class="text-brand-primary/80 max-w-6xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={introDescription || description} />
      )}
    </div>

    {introTitle && title && title !== introTitle && (
      <div class="mb-10" data-animate="fade-up">
        <h3 class="text-2xl font-black text-brand-primary uppercase tracking-wider">{title}</h3>
      </div>
    )}
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-animate-stagger>
      {jobs.map((job) => (
        <div class="group bg-white rounded-[2rem] p-8 shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-brand-tertiary/10 hover:border-accent/30 transition-all duration-500 hover:-translate-y-2 flex flex-col h-full">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-2xl bg-brand-tertiary/20 flex items-center justify-center text-accent group-hover:bg-accent group-hover:text-white transition-colors duration-500">
              <Briefcase class="w-6 h-6" />
            </div>
            <div>
              <h3 class="text-xl font-black text-brand-primary leading-tight">{job.title}</h3>
              <p class="text-xs text-accent font-bold uppercase tracking-widest mt-1">{job.type || "Full-time position"}</p>
            </div>
          </div>
          
          <div class="flex-grow">
            <p class="text-brand-primary/60 text-sm leading-relaxed mb-8">
              <span class="font-black text-brand-primary/80 block mb-2 uppercase tracking-tight text-[13px]">Key Responsibilities:</span>
              {job.responsibilities}
            </p>
          </div>
          
          <a 
            href={job.buttonHref || "/contact"} 
            class="inline-flex items-center justify-between w-full rounded-2xl bg-brand-tertiary/10 text-brand-primary px-6 py-4 font-bold hover:bg-accent hover:text-white transition-all duration-500 group/btn"
          >
            <span>{job.buttonText || "APPLY NOW"}</span>
            <ChevronRight class="w-5 h-5 transition-transform group-hover/btn:translate-x-1" />
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
