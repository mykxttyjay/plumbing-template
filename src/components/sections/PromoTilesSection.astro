---
import { Phone, ArrowRight } from "lucide-react";
import { getLocationText } from "@/config/site"

interface PromoTile {
  type: "maintenance" | "financing" | "emergency";
  tag?: string;
  title?: string;
  priceLabel?: string[];
  headline?: string[];
  subtext?: string;
  discount?: string;
  subheadline?: string[];
  phone?: string;
  buttonText: string;
  buttonHref?: string;
  bgImage?: string;
}

interface Props {
  tiles: PromoTile[];
}

const { tiles: rawTiles } = Astro.props;

// Process all text in tiles through getLocationText
const tiles = rawTiles.map(tile => ({
  ...tile,
  tag: tile.tag ? getLocationText(tile.tag) : undefined,
  title: tile.title ? getLocationText(tile.title) : undefined,
  priceLabel: tile.priceLabel ? tile.priceLabel.map(getLocationText) : undefined,
  headline: tile.headline ? tile.headline.map(getLocationText) : undefined,
  subtext: tile.subtext ? getLocationText(tile.subtext) : undefined,
  discount: tile.discount ? getLocationText(tile.discount) : undefined,
  subheadline: tile.subheadline ? tile.subheadline.map(getLocationText) : undefined,
  phone: tile.phone ? getLocationText(tile.phone) : undefined,
  buttonText: getLocationText(tile.buttonText),
}));
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-3 gap-6" data-animate-stagger>
      {tiles.map((tile) => (
        tile.type === "maintenance" ? (
          <div 
            class="rounded-lg p-8 text-center text-white relative overflow-hidden"
            style={tile.bgImage ? `background-image: url('${tile.bgImage}'); background-size: cover; background-position: center;` : ""}
          >
            {tile.bgImage ? (
              <div class="absolute inset-0 bg-brand-primary opacity-70"></div>
            ) : (
              <div class="absolute inset-0 bg-brand-primary"></div>
            )}
            <div class="absolute top-0 left-0 w-full h-1 bg-accent z-10"></div>
            <div class="relative z-10">
              <h3 class="text-xl font-bold mb-4 uppercase tracking-wide">{tile.title}</h3>
              <div class="mb-6">
                {tile.priceLabel?.map((line, i) => (
                  <p class={i === 1 ? "text-4xl md:text-5xl font-black text-sky-300 my-2" : "text-sm uppercase tracking-wide opacity-80"}>
                    {line}
                  </p>
                ))}
              </div>
              <a 
                href={tile.buttonHref || "/contact"} 
                class="inline-flex items-center justify-center rounded-md bg-accent text-white px-6 py-3 font-semibold hover:bg-accent/90 transition-colors mb-4"
                aria-label={`${tile.buttonText} - ${tile.title || 'maintenance plan'}`}
              >
                {tile.buttonText}
              </a>
              <div class="flex items-center justify-center gap-2 text-sm opacity-80">
                <Phone className="w-4 h-4" />
                <span>{tile.phone}</span>
              </div>
            </div>
          </div>
        ) : tile.type === "financing" ? (
          <div 
            class="rounded-lg p-8 text-center text-white relative overflow-hidden"
            style={tile.bgImage ? `background-image: url('${tile.bgImage}'); background-size: cover; background-position: center;` : ""}
          >
            {tile.bgImage ? (
              <div class="absolute inset-0 bg-brand-secondary opacity-70"></div>
            ) : (
              <div class="absolute inset-0 bg-brand-secondary"></div>
            )}
            <div class="absolute top-0 left-0 w-full h-1 bg-accent z-10"></div>
            <div class="relative z-10">
              <div class="mb-4">
                {tile.headline?.map((line) => (
                  <p class="text-2xl md:text-3xl font-black uppercase leading-tight">{line}</p>
                ))}
              </div>
              {tile.subtext && (
                <p class="text-sm uppercase tracking-wide opacity-80 mb-6">{tile.subtext}</p>
              )}
              <a 
                href={tile.buttonHref || "/financing"} 
                class="inline-flex items-center justify-center gap-2 rounded-md bg-white text-brand-secondary px-6 py-3 font-semibold hover:bg-white/90 transition-colors mb-4"
                aria-label={`${tile.buttonText} - ${tile.headline?.join(' ') || 'financing options'}`}
              >
                {tile.buttonText}
                <ArrowRight className="w-4 h-4" />
              </a>
              <div class="text-sm opacity-80">
                <span class="block">Phone Number:</span>
                <span class="font-semibold">{tile.phone}</span>
              </div>
            </div>
          </div>
        ) : (
          <div 
            class="rounded-lg p-8 text-center text-white relative overflow-hidden"
            style={tile.bgImage ? `background-image: url('${tile.bgImage}'); background-size: cover; background-position: center;` : ""}
          >
            {tile.bgImage ? (
              <div class="absolute inset-0 bg-accent opacity-70"></div>
            ) : (
              <div class="absolute inset-0 bg-accent"></div>
            )}
            <div class="relative z-10">
              {tile.tag && (
                <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wide">
                  {tile.tag}
                </span>
              )}
              {tile.discount && (
                <p class="text-4xl md:text-5xl font-black mb-2">{tile.discount}</p>
              )}
              <div class="mb-6">
                {tile.subheadline?.map((line) => (
                  <p class="text-lg font-bold uppercase">{line}</p>
                ))}
              </div>
              <div class="flex items-center justify-center gap-2 text-sm mb-4">
                <Phone className="w-4 h-4" />
                <span>{tile.phone}</span>
              </div>
              <a 
                href={tile.buttonHref || "/contact"} 
                class="inline-flex items-center justify-center rounded-md bg-white text-accent px-6 py-3 font-semibold hover:bg-white/90 transition-colors"
                aria-label={`${tile.buttonText} - ${tile.discount || ''} ${tile.subheadline?.join(' ') || 'special offer'}`}
              >
                {tile.buttonText}
              </a>
            </div>
          </div>
        )
      ))}
    </div>
  </div>
</section>
