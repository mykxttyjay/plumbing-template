---
import { Phone, ArrowRight } from "lucide-react";
import { getLocationText } from "@/config/site"

interface PromoTile {
  type: "maintenance" | "financing" | "emergency";
  tag?: string;
  title?: string;
  priceLabel?: string[];
  headline?: string[];
  subtext?: string;
  discount?: string;
  subheadline?: string[];
  phone?: string;
  buttonText: string;
  buttonHref?: string;
  bgImage?: string;
}

interface Props {
  tiles: PromoTile[];
}

const { tiles: rawTiles } = Astro.props;

// Process all text in tiles through getLocationText
const tiles = rawTiles.map(tile => ({
  ...tile,
  tag: tile.tag ? getLocationText(tile.tag) : undefined,
  title: tile.title ? getLocationText(tile.title) : undefined,
  priceLabel: tile.priceLabel ? tile.priceLabel.map(getLocationText) : undefined,
  headline: tile.headline ? tile.headline.map(getLocationText) : undefined,
  subtext: tile.subtext ? getLocationText(tile.subtext) : undefined,
  discount: tile.discount ? getLocationText(tile.discount) : undefined,
  subheadline: tile.subheadline ? tile.subheadline.map(getLocationText) : undefined,
  phone: tile.phone ? getLocationText(tile.phone) : undefined,
  buttonText: getLocationText(tile.buttonText),
}));
---

<section class="py-12 md:py-16" style="background-color: #bbeaf8;">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-3 gap-6" data-animate-stagger>
      {tiles.map((tile) => (
        tile.type === "maintenance" ? (
          <div class="rounded-[2rem] p-10 text-center text-white relative overflow-hidden bg-brand-primary transition-transform duration-500 hover:-translate-y-2 group">
            <div class="relative z-10">
              <h3 class="text-xl font-black mb-4 uppercase tracking-widest">{tile.title}</h3>
              <div class="mb-6">
                {tile.priceLabel?.map((line, i) => (
                  <p class={i === 1 ? "text-4xl md:text-5xl font-black text-sky-300 my-2 group-hover:scale-105 transition-transform duration-500" : "text-sm uppercase tracking-widest opacity-80"}>
                    {line}
                  </p>
                ))}
              </div>
              <a 
                href={tile.buttonHref || "/contact"} 
                class="inline-flex items-center justify-center rounded-full bg-white text-brand-primary px-8 py-3.5 font-black hover:bg-sky-50 transition-all mb-6 text-sm uppercase tracking-widest"
                aria-label={`${tile.buttonText} - ${tile.title || 'maintenance plan'}`}
              >
                {tile.buttonText}
              </a>
              <div class="flex items-center justify-center gap-2 text-sm font-bold opacity-90">
                <Phone className="w-4 h-4" />
                <span>{tile.phone}</span>
              </div>
            </div>
          </div>
        ) : tile.type === "financing" ? (
          <div class="rounded-[2rem] p-10 text-center text-white relative overflow-hidden bg-brand-secondary transition-transform duration-500 hover:-translate-y-2 group">
            <div class="relative z-10">
              <div class="mb-4">
                {tile.headline?.map((line) => (
                  <p class="text-2xl md:text-3xl font-black uppercase leading-tight tracking-tight">{line}</p>
                ))}
              </div>
              {tile.subtext && (
                <p class="text-sm uppercase tracking-widest opacity-80 mb-8">{tile.subtext}</p>
              )}
              <a 
                href={tile.buttonHref || "/financing"} 
                class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-brand-secondary px-8 py-3.5 font-black hover:bg-slate-50 transition-all mb-6 text-sm uppercase tracking-widest"
                aria-label={`${tile.buttonText} - ${tile.headline?.join(' ') || 'financing options'}`}
              >
                {tile.buttonText}
                <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" />
              </a>
              <div class="text-sm font-bold opacity-90">
                <span class="block text-xs uppercase tracking-widest mb-1 opacity-70">Contact Specialist:</span>
                <span class="text-base">{tile.phone}</span>
              </div>
            </div>
          </div>
        ) : (
          <div class="rounded-[2rem] p-10 text-center text-white relative overflow-hidden bg-brand-primary transition-transform duration-500 hover:-translate-y-2 group">
            <div class="relative z-10">
              {tile.tag && (
                <span class="inline-block bg-white/20 text-white text-xs font-black px-4 py-1.5 rounded-full mb-6 uppercase tracking-widest">
                  {tile.tag}
                </span>
              )}
              {tile.discount && (
                <p class="text-4xl md:text-5xl font-black mb-4 tracking-tighter group-hover:scale-105 transition-transform duration-500">{tile.discount}</p>
              )}
              <div class="mb-8">
                {tile.subheadline?.map((line) => (
                  <p class="text-lg font-black uppercase tracking-wide leading-tight">{line}</p>
                ))}
              </div>
              <a 
                href={tile.buttonHref || "/contact"} 
                class="inline-flex items-center justify-center rounded-full bg-white text-brand-primary px-8 py-3.5 font-black hover:bg-sky-50 transition-all mb-6 text-sm uppercase tracking-widest"
                aria-label={`${tile.buttonText} - ${tile.discount || ''} ${tile.subheadline?.join(' ') || 'special offer'}`}
              >
                {tile.buttonText}
              </a>
              <div class="flex items-center justify-center gap-2 text-sm font-bold opacity-90">
                <Phone className="w-4 h-4" />
                <span>{tile.phone}</span>
              </div>
            </div>
          </div>
        )
      ))}
    </div>
  </div>
</section>
