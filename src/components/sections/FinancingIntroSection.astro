---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  benefits?: string[];
}

const { title: raw_title, description: raw_description, subtitle: raw_subtitle, benefits = [] } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const subtitle = raw_subtitle ? getLocationText(raw_subtitle) : raw_subtitle;
---

<section class="py-12 md:py-16" style="background-color: #eaf9fe;">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16" data-animate="fade-up">
        <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-6" style="color: #40c4eb; border: 1.5px solid rgba(64,196,235,0.6); background-color: rgba(64,196,235,0.12);">
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Financing Plans
        </span>

        <h2 class="font-black mb-6 leading-tight" style="font-size: 43px;">{title}</h2>
        <p class="text-brand-primary/80 leading-relaxed mx-auto max-w-4xl" style="font-size: 18px;" set:html={description} />
      </div>
      
      {subtitle && benefits.length > 0 && (
        <div class="bg-white border-2 rounded-[2rem] p-10 md:p-14 transition-all duration-500" style="border-color: rgba(9, 31, 65, 0.05);" data-animate="fade-up">
          <div class="flex items-center justify-center gap-4 mb-10">
            <div class="h-px w-8 bg-brand-primary/10"></div>
            <h3 class="text-xl font-black text-brand-primary text-center uppercase tracking-wider">{subtitle}</h3>
            <div class="h-px w-8 bg-brand-primary/10"></div>
          </div>
          
          <ul class="grid sm:grid-cols-2 gap-x-12 gap-y-6">
            {benefits.map((benefit) => (
              <li class="flex items-center gap-4 group">
                <span class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-500 group-hover:scale-110 border-2" style="background-color: rgba(64, 196, 235, 0.08); border-color: rgba(64, 196, 235, 0.3);">
                  <svg class="w-5 h-5" style="color: #40c4eb;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                  </svg>
                </span>
                <span class="font-bold text-brand-primary/80" style="font-size: 16px;">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </div>
</section>
