---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description: string;
  calloutText: string;
  phone?: string;
  buttonText?: string;
  buttonHref?: string;
}

const { 
  title: raw_title, 
  description: raw_description, 
  calloutText: raw_calloutText,
  phone: raw_phone = "{phone}",
  buttonText = "Sign Up Online",
  buttonHref = "/contact"
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : "";
const description = raw_description ? getLocationText(raw_description) : "";
const calloutText = raw_calloutText ? getLocationText(raw_calloutText) : "";
const phone = getLocationText(raw_phone);
const phoneRaw = getLocationText("{phoneRaw}");
---

<section class="py-12 md:py-16 bg-[#091f41] text-white relative overflow-hidden">
  <!-- Dynamic Background Effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[40%] -right-[10%] w-[600px] h-[600px] bg-[#40c4eb]/10 rounded-full blur-[120px]"></div>
    <div class="absolute -bottom-[40%] -left-[10%] w-[500px] h-[500px] bg-accent/5 rounded-full blur-[100px]"></div>
    <div class="absolute inset-0 opacity-[0.03] mix-blend-overlay"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-12 lg:gap-20 items-center" data-animate="fade-up">
      {/* Left Column: Text Content */}
      <div class="text-center lg:text-left">
        <h2 class="font-black mb-6 leading-tight lg:whitespace-nowrap" style="font-size: 43px;">{title}</h2>
        <p class="text-white/80 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed" style="font-size: 18px;" set:html={description} />
        
        <div class="inline-block px-6 py-3 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm">
          <p class="text-xl font-bold text-[#40c4eb]" set:html={calloutText} />
        </div>
      </div>

      {/* Right Column: Actions */}
      <div class="flex flex-col gap-5 items-center lg:items-end lg:ml-auto">
        <a href={`tel:${phoneRaw}`} class="group inline-flex items-center justify-between gap-4 rounded-2xl bg-white text-[#091f41] px-6 py-5 text-xl font-bold shadow-[0_20px_40px_rgba(255,255,255,0.1)] hover:bg-[#40c4eb] hover:text-white transition-all duration-500 hover:translate-y-[-4px] w-full max-w-[320px]">
          <div class="w-10 h-10 rounded-full bg-[#091f41]/5 flex items-center justify-center group-hover:bg-white/20 shrink-0">
            <svg class="w-5 h-5 transition-transform group-hover:rotate-[15deg]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <span class="uppercase tracking-wider whitespace-nowrap">Call Us Now</span>
          <div class="w-10 h-10 shrink-0"></div>
        </a>

        <a href={buttonHref} class="group inline-flex items-center justify-center gap-4 rounded-2xl border-2 border-white/20 bg-white/5 backdrop-blur-sm px-8 py-5 text-xl font-bold hover:bg-white hover:text-[#091f41] hover:border-white transition-all duration-500 hover:translate-y-[-4px] w-full max-w-[320px]">
          <span>{buttonText}</span>
          <svg class="w-6 h-6 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
