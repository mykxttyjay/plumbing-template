---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description: string;
  calloutText: string;
  phone?: string;
  buttonText?: string;
  buttonHref?: string;
}

const { 
  title: raw_title, 
  description: raw_description, 
  calloutText: raw_calloutText,
  phone: raw_phone = "{phone}",
  buttonText = "Sign Up Online",
  buttonHref = "/contact"
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : "";
const description = raw_description ? getLocationText(raw_description) : "";
const calloutText = raw_calloutText ? getLocationText(raw_calloutText) : "";
const phone = getLocationText(raw_phone);
const phoneRaw = getLocationText("{phoneRaw}");
---

<section class="py-16 md:py-20 bg-primary text-primary-foreground">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center" data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
      <p class="text-lg opacity-90 mb-8" set:html={description} />
      <p class="text-xl font-semibold mb-8" set:html={calloutText} />
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`tel:${phoneRaw}`} class="inline-flex items-center justify-center rounded-md bg-background text-foreground px-8 py-4 text-lg font-semibold hover:bg-background/90 transition-colors">
          Call {phone}
        </a>
        <a href={buttonHref} class="inline-flex items-center justify-center rounded-md border-2 border-primary-foreground px-8 py-4 text-lg font-semibold hover:bg-primary-foreground/10 transition-colors">
          {buttonText}
        </a>
      </div>
    </div>
  </div>
</section>
