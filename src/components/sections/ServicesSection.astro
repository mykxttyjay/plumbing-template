---
import { getLocationText } from "@/config/site"

interface Service {
  title: string;
  description: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: Service[];
}

interface Props {
  title: string;
  description: string;
  categories: ServiceCategory[];
}

const { title: raw_title, description: raw_description, categories } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
---

<section class="py-16 md:py-24 relative overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1712145176725-673500482322?q=80&w=1332&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
      alt="Background" 
      class="w-full h-full object-cover blur-sm"
      loading="lazy"
    />
    <!-- Overlay for readability -->
    <div class="absolute inset-0 bg-white/40"></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-12" data-animate="fade-up">
      <h2 class="font-bold mb-4" style="font-size: 43px;">{title}</h2>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />
    </div>
    
    <div class="space-y-12" data-animate-stagger>
      {categories.map((category) => (
        <div>
          <h3 class="text-2xl font-bold mb-6 text-center flex items-center justify-center gap-3">
            <span class="w-8 h-0.5 bg-accent rounded-full"></span>
            {category.title}
            <span class="w-8 h-0.5 bg-accent rounded-full"></span>
          </h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {category.services.map((service) => (
              service.href ? (
                <a href={service.href} class="group bg-card border rounded-lg p-6 hover:shadow-md hover:border-accent/30 transition-all cursor-pointer">
                  <h4 class="font-semibold mb-2 group-hover:text-accent transition-colors">{service.title}</h4>
                  <p class="text-sm text-muted-foreground" set:html={service.description} />
                </a>
              ) : (
                <div class="bg-card border rounded-lg p-6 cursor-default">
                  <h4 class="font-semibold mb-2">{service.title}</h4>
                  <p class="text-sm text-muted-foreground" set:html={service.description} />
                </div>
              )
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
