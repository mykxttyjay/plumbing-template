---
import { Droplet } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface Service {
  title: string;
  description: string;
  href?: string;
  icon?: string;
}

interface ServiceCategory {
  title: string;
  services: Service[];
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  categories: ServiceCategory[];
}

const { badge: raw_badge, title: raw_title, description: raw_description, categories } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;

// Map category titles to banner images
const CATEGORY_IMAGES: Record<string, string> = {
  'Residential Plumbing Services': '/images/photos/freepik-male-plumber-working-fix-problems-client-s-house_23-2150990700.jpg',
  'Commercial Plumbing Services':  '/images/photos/freepik-man-installs-heating-system-house-checks-pipes-with-wrench_169016-55834.jpg',
  'Specialty Plumbing Services':   '/images/photos/freepik-female-plumber-working-fix-problems-client-s-house_23-2150990725.jpg',
  'Maintenance Services':          '/images/photos/plumber-bathroom.jpg',
};
---

<section class="py-12 md:py-16 relative overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1604147706283-d7119b5b822c?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
      alt="Background" 
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <!-- Overlay for readability -->
    <div class="absolute inset-0 bg-white/40"></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-12" data-animate="fade-up">
      {badge && (
        <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-3" style="color: #40c4eb; border: 1.5px solid rgba(64,196,235,0.6); background-color: rgba(64,196,235,0.12);">
          <Droplet class="w-3 h-3 flex-shrink-0" />
          {badge}
        </span>
      )}
      <h2 class="font-extrabold mb-4" style="font-size: 43px;">{title}</h2>
      <p class="text-brand-primary/80 max-w-3xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />
    </div>

    {/* Grid layout with tabs on left and content on right */}
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      {/* Left side: Vertical tabs */}
      <div class="lg:col-span-1 flex lg:flex-col gap-3 overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0">
        {categories.map((category, index) => (
          <button
            data-tab-button={index}
            class="services-tab-button flex-shrink-0 lg:flex-shrink px-6 py-4 rounded-clay-sm text-base font-semibold transition-all duration-300 whitespace-nowrap lg:whitespace-normal text-left w-full shadow-clay-button clay-squish"
            data-active={index === 0 ? 'true' : 'false'}
            style={index === 0 ? 'background-color: #40c4eb; color: white;' : 'background-color: rgba(255, 255, 255, 0.8); color: rgba(0, 0, 0, 0.6);'}
          >
            {category.title}
          </button>
        ))}
      </div>

      {/* Right side: Content */}
      <div class="lg:col-span-3 relative">
        {categories.map((category, categoryIndex) => (
          <div
            data-tab-content={categoryIndex}
            class="services-tab-content transition-opacity duration-300"
            data-active={categoryIndex === 0 ? 'true' : 'false'}
            style={categoryIndex === 0 ? 'opacity: 1;' : 'opacity: 0; position: absolute; inset: 0; pointer-events: none;'}
          >
            {/* Category image banner */}
            {CATEGORY_IMAGES[category.title] && (
              <div class="relative w-full mb-8 rounded-clay overflow-hidden h-48 md:h-64 shadow-clay-card">
                <img
                  src={CATEGORY_IMAGES[category.title]}
                  alt={category.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
                <div class="absolute inset-0 flex items-end bg-black/50 p-6">
                  <div>
                    <h3 class="text-xl md:text-2xl font-extrabold text-white">{category.title}</h3>
                    <div class="w-12 h-0.5 bg-accent mt-2 rounded-full"></div>
                  </div>
                </div>
              </div>
            )}
            <div class="grid sm:grid-cols-2 gap-4">
              {category.services.map((service, serviceIndex) => (
                <a
                  href={service.href || '#'}
                  class="services-card group relative overflow-hidden rounded-clay p-5 clay-lift transition-all duration-300 flex items-center gap-4 cursor-pointer no-underline"
                  style={`animation-delay: ${serviceIndex * 50}ms;`}
                >
                  {/* Gradient accent bar on left */}
                  <span class="services-card-bar absolute left-0 top-0 bottom-0 w-1 rounded-l-clay transition-all duration-300" style="background: linear-gradient(180deg, #40c4eb, #091f41);"></span>

                  {/* Hover background glow */}
                  <span class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(135deg, rgba(64,196,235,0.10) 0%, rgba(9,31,65,0.06) 100%);"></span>

                  {/* Icon */}
                  <div class="relative shrink-0 w-14 h-14 rounded-xl flex items-center justify-center overflow-hidden shadow-clay-button transition-all duration-300 group-hover:scale-110 group-hover:shadow-clay-button-hover" style="background: linear-gradient(135deg, rgba(64,196,235,0.18) 0%, rgba(9,31,65,0.10) 100%); border: 1.5px solid rgba(64,196,235,0.25);">
                    {service.icon ? (
                      <img src={service.icon} alt="" class="w-8 h-8 object-contain" style="filter: brightness(0) saturate(100%) invert(62%) sepia(80%) saturate(400%) hue-rotate(160deg) brightness(105%);" />
                    ) : (
                      <svg class="w-6 h-6" style="color: #40c4eb;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                      </svg>
                    )}
                  </div>

                  {/* Text */}
                  <div class="relative flex-1 min-w-0">
                    <h4 class="font-bold leading-snug mb-0.5 transition-colors duration-300 group-hover:text-accent" style="color: #091f41; font-size: 18px;">
                      {service.title}
                    </h4>
                    <p class="text-clay-muted leading-relaxed line-clamp-1" style="font-size: 16px;" set:html={service.description} />
                  </div>

                  {/* Arrow indicator */}
                  <div class="relative shrink-0 w-7 h-7 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-300" style="background-color: rgba(64,196,235,0.15);">
                    <svg class="w-3.5 h-3.5" style="color: #40c4eb;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .services-card {
    animation: fadeInSlideUp 0.3s ease-out forwards;
    opacity: 0;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(64, 196, 235, 0.18);
    box-shadow: 0 4px 18px rgba(9, 31, 65, 0.08), 0 1px 4px rgba(64,196,235,0.08);
  }

  .services-card:hover {
    border-color: rgba(64, 196, 235, 0.45);
    box-shadow: 0 8px 28px rgba(9, 31, 65, 0.13), 0 2px 8px rgba(64,196,235,0.18);
    transform: translateY(-2px);
  }

  .services-card-bar {
    width: 3px;
  }

  .services-card:hover .services-card-bar {
    width: 5px;
  }

  @keyframes fadeInSlideUp {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function initServicesTabs() {
    const tabButtons = document.querySelectorAll<HTMLButtonElement>('.services-tab-button');
    const tabContents = document.querySelectorAll<HTMLElement>('.services-tab-content');

    tabButtons.forEach((button, index) => {
      button.addEventListener('click', () => {
        // Update buttons
        tabButtons.forEach((btn, i) => {
          if (i === index) {
            btn.setAttribute('data-active', 'true');
            btn.style.backgroundColor = '#40c4eb';
            btn.style.color = 'white';
          } else {
            btn.setAttribute('data-active', 'false');
            btn.style.backgroundColor = 'rgba(255, 255, 255, 0.8)';
            btn.style.color = 'rgba(0, 0, 0, 0.6)';
          }
        });

        // Update content
        tabContents.forEach((content, i) => {
          if (i === index) {
            content.setAttribute('data-active', 'true');
            content.style.opacity = '1';
            content.style.position = 'relative';
            content.style.pointerEvents = 'auto';
          } else {
            content.setAttribute('data-active', 'false');
            content.style.opacity = '0';
            content.style.position = 'absolute';
            content.style.pointerEvents = 'none';
          }
        });
      });
    });
  }

  initServicesTabs();
  document.addEventListener('astro:page-load', initServicesTabs);

  // Enhanced parallax effect for background
  function initParallax() {
    const section = document.querySelector<HTMLElement>('.services-section');
    const bgParallax = document.querySelector<HTMLElement>('.services-bg-parallax');
    
    if (!section || !bgParallax) return;

    const handleScroll = () => {
      const scrollY = window.scrollY;
      const sectionTop = section.offsetTop;
      const windowHeight = window.innerHeight;
      
      // Calculate parallax offset based on scroll position
      // The background moves at 40% of the scroll speed for a nice parallax effect
      const parallaxOffset = (scrollY - sectionTop + windowHeight) * 0.4;
      
      bgParallax.style.transform = `translateY(${parallaxOffset}px)`;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    
    // Cleanup on page transition
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', handleScroll);
    }, { once: true });
  }

  initParallax();
  document.addEventListener('astro:page-load', initParallax);
</script>
