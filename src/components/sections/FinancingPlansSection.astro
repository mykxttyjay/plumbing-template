---
import { getLocationText } from "@/config/site"

import { Percent, CircleDollarSign, Calendar, CheckCircle, Home, Building2, Wrench, Settings, ArrowRight, MapPin, Clock } from "lucide-react"

interface Item {
  title: string;
  text?: string;
  href?: string;
  icon?: string;
  image?: string;
}

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  items: Item[];
  variant?: "plans" | "services" | "features";
}

const { badge: raw_badge, title: raw_title, subtitle: raw_subtitle, items, variant = "plans" } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const subtitle = raw_subtitle ? getLocationText(raw_subtitle) : raw_subtitle;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;

const iconMap = {
  "percent": Percent,
  "zero": CircleDollarSign,
  "calendar": Calendar,
  "check": CheckCircle,
  "home": Home,
  "building": Building2,
  "wrench": Wrench,
  "settings": Settings,
  "map": MapPin,
  "clock": Clock
};

const defaultIcon = variant === "services" ? Wrench : CheckCircle;
---

{variant === "features" ? (
  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12" data-animate="fade-up">
        {badge && (
          <span class="inline-block text-sm font-semibold text-accent uppercase tracking-wide border-b-2 border-accent pb-1">{badge}</span>
        )}
        <h2 class="text-3xl md:text-4xl font-extrabold mt-4 mb-4">{title}</h2>
        <div class="w-16 h-1 bg-accent mx-auto mb-4 rounded-full"></div>
        {subtitle && <p class="text-clay-muted max-w-3xl mx-auto" set:html={subtitle} />}
      </div>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto" data-animate-stagger>
        {items.map((item) => {
          const IconComponent = iconMap[item.icon as keyof typeof iconMap] || CheckCircle;
          return (
            <div class="text-center p-6 glass-clay shadow-clay-card rounded-clay clay-lift hover:shadow-clay-card-hover transition-all">
              <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4 shadow-clay-button">
                <IconComponent className="w-8 h-8 text-accent" />
              </div>
              <h3 class="text-xl font-extrabold mb-3">{item.title}</h3>
              {item.text && <p class="text-clay-muted" set:html={item.text} />}
            </div>
          );
        })}
      </div>
    </div>
  </section>
) : variant === "services" ? (
  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12" data-animate="fade-up">
        <h2 class="text-3xl md:text-4xl font-extrabold">{title}</h2>
        <div class="w-16 h-1 bg-accent mx-auto mt-4 rounded-full"></div>
        {subtitle && <p class="text-clay-muted max-w-3xl mx-auto mt-4" set:html={subtitle} />}
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-8xl mx-auto" data-animate-stagger>
        {items.map((item) => {
          return (
            <div class="glass-clay shadow-clay-card rounded-clay overflow-hidden clay-lift hover:shadow-clay-card-hover transition-all">
              {item.image && (
                <div class="w-full h-48 bg-muted/50 flex items-center justify-center overflow-hidden">
                  <img src={item.image} alt={item.title} class="w-full h-full object-cover" />
                </div>
              )}
              <div class="p-6 text-center">
                <h3 class="text-lg font-extrabold mb-2">{item.title}</h3>
                {item.text && <p class="text-sm text-clay-muted leading-relaxed" set:html={item.text} />}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
) : (
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12" data-animate="fade-up">
        <h2 class="text-3xl md:text-4xl font-extrabold mb-4">{title}</h2>
        <div class="w-16 h-1 bg-accent mx-auto mb-4 rounded-full"></div>
        {subtitle && <p class="text-clay-muted max-w-3xl mx-auto" set:html={subtitle} />}
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto" data-animate-stagger>
        {items.map((item) => {
          const IconComponent = iconMap[item.icon as keyof typeof iconMap] || defaultIcon;
          return (
            <div class="glass-clay shadow-clay-card rounded-clay p-6 text-center clay-lift hover:shadow-clay-card-hover transition-all">
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-accent/10 flex items-center justify-center shadow-clay-button">
                <IconComponent className="w-8 h-8 text-accent" />
              </div>
              <h3 class="text-lg font-extrabold mb-2">{item.title}</h3>
              {item.text && <p class="text-sm text-clay-muted" set:html={item.text} />}
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}
