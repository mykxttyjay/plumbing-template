---
import { Droplet, ArrowUpRight } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface Props {
  badge?: string;
  title: string;
  description: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  images?: string[];
  imageAlts?: string[];
}

const { 
  badge: raw_badge, 
  title: raw_title, 
  description: raw_description, 
  features = [], 
  buttonText, 
  buttonHref,
  imagePosition = "left",
  images = [],
  imageAlts = []
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
---

<section class="py-16 md:py-24 bg-[#f1fbfe] relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class={`grid md:grid-cols-2 gap-16 items-start ${imagePosition === "right" ? "md:flex-row-reverse" : ""}`}>
      {imagePosition === "left" && (
        <div class="relative" data-animate="fade-right">
          {images.length > 0 ? (
            <div class="relative">
              {/* First image - larger, positioned top right with clay styling */}
              <div class="relative z-0 ml-auto w-[70%] overflow-hidden shadow-clay-card clay-lift rounded-clay-lg">
                <img 
                  src={images[0].includes('ucarecdn.com') ? images[0].replace(/\/preview\/\d+x\d+/, '/preview/600x600').concat('-/format/webp/') : images[0]} 
                  alt={imageAlts[0] || `${title} - photo 1`} 
                  class="w-full h-auto object-cover transition-transform duration-700 hover:scale-105" 
                  loading="lazy"
                  width="600"
                  height="600"
                  decoding="async"
                />
              </div>
              {/* Second image - smaller, positioned bottom left with clay styling */}
              {images[1] && (
                <div class="relative z-20 -mt-32 w-[65%] overflow-hidden shadow-clay-card-hover clay-lift rounded-clay">
                  <img 
                    src={images[1].includes('ucarecdn.com') ? images[1].replace(/\/preview\/\d+x\d+/, '/preview/500x500').concat('-/format/webp/') : images[1]} 
                    alt={imageAlts[1] || `${title} - photo 2`} 
                    class="w-full h-auto object-cover transition-transform duration-700 hover:scale-105" 
                    loading="lazy"
                    width="500"
                    height="500"
                    decoding="async"
                  />
                </div>
              )}
            </div>
          ) : (
            <div class="relative">
              <div class="relative z-0 ml-auto w-[70%] aspect-square bg-muted flex items-center justify-center shadow-clay-card rounded-clay-lg">
                <span class="text-muted-foreground text-sm">Image 1</span>
              </div>
              <div class="relative z-20 -mt-32 w-[65%] aspect-square bg-muted flex items-center justify-center shadow-clay-card-hover rounded-clay">
                <span class="text-muted-foreground text-sm">Image 2</span>
              </div>
            </div>
          )}
        </div>
      )}
      <div data-animate="fade-up">
        {badge && (
          <span class="inline-flex items-center gap-2 text-accent text-sm font-bold py-2 uppercase tracking-wide">
            <Droplet class="w-4 h-4 animate-bounce" />
            {badge}
          </span>
        )}
        <h2 class="font-extrabold mt-2 mb-4" style="font-size: 43px;" set:html={title}></h2>
        <p class="text-clay-muted mb-8 leading-relaxed" style="font-size: 18px;" set:html={description} />
        {features.length > 0 && (
          <ul class="space-y-5 mb-10">
            {features.map((feature) => (
              <li class="flex items-center gap-4 group">
                <span class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:scale-110 shadow-clay-button" style="background-color: rgba(64, 196, 235, 0.1);">
                  <svg class="w-6 h-6" style="color: #40c4eb;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                  </svg>
                </span>
                <span class="text-lg font-semibold" style="color: #091f41;">{feature}</span>
              </li>
            ))}
          </ul>
        )}
        {buttonText && buttonHref && (
          <a href={buttonHref} class="inline-flex items-center justify-between rounded-clay-sm bg-accent text-accent-foreground pl-8 pr-2 py-2 text-lg font-bold shadow-clay-button clay-squish group hover:-translate-y-1 hover:shadow-clay-button-hover transition-all duration-200">
            <span class="mr-4">{buttonText}</span>
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-white flex-shrink-0 transition-all duration-300 group-hover:bg-highlight group-hover:rotate-45">
              <ArrowUpRight class="w-6 h-6 text-black transition-colors duration-300 group-hover:text-brand-primary" />
            </span>
          </a>
        )}
      </div>
      {imagePosition === "right" && (
        <div class="grid grid-cols-2 gap-6" data-animate="fade-left">
          {images.length > 0 ? (
            images.map((img, i) => (
              <div class="aspect-square overflow-hidden clay-lift shadow-clay-card hover:shadow-clay-card-hover transition-all duration-500 rounded-clay">
                <img 
                  src={img.includes('ucarecdn.com') ? img.replace(/\/preview\/\d+x\d+/, '/preview/480x480').concat('-/format/webp/') : img} 
                  alt={imageAlts[i] || `${title} - photo ${i + 1}`} 
                  class="w-full h-full object-cover transition-transform duration-700 hover:scale-110" 
                  loading="lazy"
                  width="480"
                  height="480"
                  decoding="async"
                />
              </div>
            ))
          ) : (
            <>
              <div class="aspect-square bg-muted flex items-center justify-center rounded-clay shadow-clay-card">
                <span class="text-muted-foreground text-sm">Image 1</span>
              </div>
              <div class="aspect-square bg-muted flex items-center justify-center rounded-clay shadow-clay-card">
                <span class="text-muted-foreground text-sm">Image 2</span>
              </div>
            </>
          )}
        </div>
      )}
    </div>
  </div>
</section>
