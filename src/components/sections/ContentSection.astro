---
import { Droplet, ArrowUpRight } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface Props {
  badge?: string;
  title: string;
  description: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  images?: string[];
  imageAlts?: string[];
}

const { 
  badge: raw_badge, 
  title: raw_title, 
  description: raw_description, 
  features = [], 
  buttonText, 
  buttonHref,
  imagePosition = "left",
  images = [],
  imageAlts = []
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
---

<section class="py-12 md:py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class={`grid md:grid-cols-2 gap-12 items-start ${imagePosition === "right" ? "md:flex-row-reverse" : ""}`}>
      {imagePosition === "left" && (
        <div class="relative" data-animate="fade-right">
          {images.length > 0 ? (
            <div class="relative">
              {/* First image - larger, positioned top right */}
              <div class="relative z-0 ml-auto w-[70%] rounded-lg overflow-hidden shadow-xl">
                <img 
                  src={images[0].includes('ucarecdn.com') ? images[0].replace(/\/preview\/\d+x\d+/, '/preview/600x600').concat('-/format/webp/') : images[0]} 
                  alt={imageAlts[0] || `${title} - photo 1`} 
                  class="w-full h-auto object-cover" 
                  loading="lazy"
                  width="600"
                  height="600"
                  decoding="async"
                />
              </div>
              {/* Second image - smaller, positioned bottom left, overlapping ON TOP */}
              {images[1] && (
                <div class="relative z-20 -mt-32 w-[65%] rounded-lg overflow-hidden shadow-xl">
                  <img 
                    src={images[1].includes('ucarecdn.com') ? images[1].replace(/\/preview\/\d+x\d+/, '/preview/500x500').concat('-/format/webp/') : images[1]} 
                    alt={imageAlts[1] || `${title} - photo 2`} 
                    class="w-full h-auto object-cover" 
                    loading="lazy"
                    width="500"
                    height="500"
                    decoding="async"
                  />
                </div>
              )}
            </div>
          ) : (
            <div class="relative">
              <div class="relative z-0 ml-auto w-[70%] aspect-square bg-muted rounded-lg flex items-center justify-center shadow-xl">
                <span class="text-muted-foreground text-sm">Image 1</span>
              </div>
              <div class="relative z-20 -mt-32 w-[65%] aspect-square bg-muted rounded-lg flex items-center justify-center shadow-xl">
                <span class="text-muted-foreground text-sm">Image 2</span>
              </div>
            </div>
          )}
        </div>
      )}
      <div data-animate="fade-up">
        {badge && (
          <span class="inline-flex items-center gap-2 text-accent text-sm font-bold py-2 uppercase tracking-wide">
            <Droplet class="w-4 h-4 animate-bounce" />
            {badge}
          </span>
        )}
        <h2 class="font-bold mt-2 mb-4" style="font-size: 43px;" set:html={title}></h2>
        <p class="text-muted-foreground mb-8 leading-relaxed" style="font-size: 18px;" set:html={description} />
        {features.length > 0 && (
          <ul class="space-y-4 mb-8">
            {features.map((feature) => (
              <li class="flex items-center gap-4">
                <span class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: rgba(64, 196, 235, 0.1);">
                  <svg class="w-6 h-6" style="color: #40c4eb;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                  </svg>
                </span>
                <span class="text-lg" style="color: #091f41;">{feature}</span>
              </li>
            ))}
          </ul>
        )}
        {buttonText && buttonHref && (
          <a href={buttonHref} class="inline-flex items-center justify-between rounded-full bg-accent text-accent-foreground pl-8 pr-2 py-2 text-lg font-semibold transition-colors shadow-lg shadow-accent/30 group hover:bg-brand-primary hover:text-white">
            <span class="mr-4">{buttonText}</span>
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-white flex-shrink-0 transition-colors group-hover:bg-highlight">
              <ArrowUpRight class="w-6 h-6 text-black" />
            </span>
          </a>
        )}
      </div>
      {imagePosition === "right" && (
        <div class="grid grid-cols-2 gap-4" data-animate="fade-left">
          {images.length > 0 ? (
            images.map((img, i) => (
              <div class="aspect-square rounded-lg overflow-hidden">
                <img 
                  src={img.includes('ucarecdn.com') ? img.replace(/\/preview\/\d+x\d+/, '/preview/480x480').concat('-/format/webp/') : img} 
                  alt={imageAlts[i] || `${title} - photo ${i + 1}`} 
                  class="w-full h-full object-cover" 
                  loading="lazy"
                  width="480"
                  height="480"
                  decoding="async"
                />
              </div>
            ))
          ) : (
            <>
              <div class="aspect-square bg-muted rounded-lg flex items-center justify-center">
                <span class="text-muted-foreground text-sm">Image 1</span>
              </div>
              <div class="aspect-square bg-muted rounded-lg flex items-center justify-center">
                <span class="text-muted-foreground text-sm">Image 2</span>
              </div>
            </>
          )}
        </div>
      )}
    </div>
  </div>
</section>
