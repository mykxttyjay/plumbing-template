---
import { getLocationText } from "@/config/site"
import { Droplet, Phone, Mail, MapPin } from '@lucide/astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  phone?: string;
  email?: string;
  address?: string;
  serviceOptions?: string[];
  planOptions?: string[];
}

const {
  title: raw_title = "Get in Touch with {fullName}",
  description: raw_description = "Fill out the form, and a member of our team will get back to you promptly. Whether you're looking for a quick repair, a detailed quote, or general advice, we've got you covered.",
  image = "/images/photos/unsplash-1621905251189-08b45d6a269e-w800.jpg",
  phone: raw_phone = "{phone}",
  email: raw_email = "{email}",
  address: raw_address = "{city}, {state}",
  serviceOptions = ["Residential Plumbing", "Commercial Plumbing", "Emergency Service", "Maintenance", "Other"],
  planOptions = ["Yes", "No", "Not Sure"]
} = Astro.props;

// Process text placeholders
const title = getLocationText(raw_title);
const description = getLocationText(raw_description);
const phone = getLocationText(raw_phone);
const email = getLocationText(raw_email);
const address = getLocationText(raw_address);
---

<!-- Contact Info Header -->
<section class="py-12 md:py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12" data-animate="fade-up">
      <h2 class="font-black mb-6 leading-tight text-brand-primary" style="font-size: 40px;">{title}</h2>
      {description && <p class="text-brand-primary/80 max-w-4xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />}
      
      <div class="flex flex-wrap justify-center gap-6 md:gap-8 mt-12">
        <div class="flex items-center gap-4 bg-brand-tertiary/10 backdrop-blur-sm rounded-full px-8 py-4 border border-brand-tertiary/10">
          <div class="w-12 h-12 rounded-full bg-[#40c4eb] flex items-center justify-center shadow-lg text-white">
            <Phone class="w-5 h-5" />
          </div>
          <div class="text-left">
            <p class="text-[10px] text-brand-primary/60 uppercase tracking-widest font-black">Phone</p>
            <a href={`tel:${phone}`} class="font-black text-lg text-brand-primary hover:text-accent transition-colors leading-none">{phone}</a>
          </div>
        </div>
        
        <div class="flex items-center gap-4 bg-brand-tertiary/10 backdrop-blur-sm rounded-full px-8 py-4 border border-brand-tertiary/10">
          <div class="w-12 h-12 rounded-full bg-[#40c4eb] flex items-center justify-center shadow-lg text-white">
            <Mail class="w-5 h-5" />
          </div>
          <div class="text-left">
            <p class="text-[10px] text-brand-primary/60 uppercase tracking-widest font-black">Email Address</p>
            <a href={`mailto:${email}`} class="font-black text-lg text-brand-primary hover:text-accent transition-colors leading-none">{email}</a>
          </div>
        </div>
        
        <div class="flex items-center gap-4 bg-brand-tertiary/10 backdrop-blur-sm rounded-full px-8 py-4 border border-brand-tertiary/10">
          <div class="w-12 h-12 rounded-full bg-[#40c4eb] flex items-center justify-center shadow-lg text-white">
            <MapPin class="w-5 h-5" />
          </div>
          <div class="text-left">
            <p class="text-[10px] text-brand-primary/60 uppercase tracking-widest font-black">Address</p>
            <span class="font-black text-lg text-brand-primary leading-none">{address}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Form Section with Image -->
<section class="py-12 md:py-16 bg-[#bbeaf8] relative overflow-hidden">
  <!-- Decorative Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center max-w-6xl mx-auto">
      <!-- Image Side -->
      <div class="relative order-2 lg:order-1" data-animate="fade-right">
        <!-- Main Image Container -->
        <div class="relative">
          <!-- Decorative background glow -->
          <div class="absolute -inset-10 bg-[#40c4eb]/20 rounded-full blur-[80px] opacity-50"></div>
          
          <div class="relative rounded-[2.5rem] overflow-hidden border-8 border-white/10 shadow-[0_32px_64px_-15px_rgba(0,0,0,0.3)] bg-gray-900 group">
            <img 
              src={image} 
              alt="Professional plumber ready to help" 
              class="w-full h-full object-cover aspect-[4/5] scale-105 group-hover:scale-110 transition-transform duration-700"
            />
            <!-- Overlay gradient -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#091f41]/60 via-transparent to-transparent opacity-60"></div>
          </div>

          <!-- Floating badge element -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-4 shadow-xl border border-brand-tertiary/20 flex items-center gap-3 animate-float">
            <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center text-white">
              <Phone class="w-5 h-5" />
            </div>
            <div>
              <p class="text-[10px] text-brand-primary/40 uppercase tracking-widest font-black leading-tight">Emergency? Call Now</p>
              <p class="font-black text-brand-primary leading-tight">{phone}</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Form Side -->
      <div class="order-1 lg:order-2" data-animate="fade-left">
        <div class="bg-white rounded-[2rem] p-8 md:p-10 shadow-[0_32px_64px_-15px_rgba(0,0,0,0.5)] relative overflow-hidden">
          <!-- Form Header Accent -->
          <div class="absolute top-0 left-0 right-0 h-2 bg-accent"></div>
          
          <h3 class="text-2xl md:text-3xl font-black mb-1 text-brand-primary">Contact Form</h3>
          <p class="text-brand-primary/60 text-sm mb-8 font-medium">We'll get back to you within 24 hours</p>
          
          <form class="space-y-3">
            <div>
              <label for="name" class="block text-xs font-semibold mb-1 text-gray-700">Name*</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all bg-gray-50/50 text-sm"
                placeholder="Your full name"
              />
            </div>
            
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <label for="email" class="block text-xs font-semibold mb-1 text-gray-700">Email Address*</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all bg-gray-50/50 text-sm"
                  placeholder="you@email.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-xs font-semibold mb-1 text-gray-700">Phone</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone"
                  class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all bg-gray-50/50 text-sm"
                  placeholder="(123) 456-7890"
                />
              </div>
            </div>
            
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <label for="plan" class="block text-xs font-semibold mb-1 text-gray-700">Are You Interested In A Plan?</label>
                <div class="relative">
                  <select 
                    id="plan" 
                    name="plan"
                    class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all bg-gray-50/50 appearance-none cursor-pointer text-sm"
                  >
                    <option value="">Select an option</option>
                    {planOptions.map((option) => (
                      <option value={option.toLowerCase()}>{option}</option>
                    ))}
                  </select>
                  <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </div>
              </div>
              <div>
                <label for="service" class="block text-xs font-semibold mb-1 text-gray-700">Which Service Do You Need?</label>
                <div class="relative">
                  <select 
                    id="service" 
                    name="service"
                    class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all bg-gray-50/50 appearance-none cursor-pointer text-sm"
                  >
                    <option value="">Select a service</option>
                    {serviceOptions.map((option) => (
                      <option value={option.toLowerCase().replace(/\s+/g, '-')}>{option}</option>
                    ))}
                  </select>
                  <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </div>
              </div>
            </div>
            
            <div>
              <label for="message" class="block text-xs font-semibold mb-1 text-gray-700">Message*</label>
              <textarea 
                id="message" 
                name="message" 
                rows="3"
                required
                class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all bg-gray-50/50 resize-none text-sm"
                placeholder="Tell us about your plumbing needs..."
              ></textarea>
            </div>
            
            <div>
              <label for="verification" class="block text-xs font-semibold mb-1 text-gray-700">Verification*</label>
              <input 
                type="text" 
                id="verification" 
                name="verification"
                placeholder="Enter the code shown"
                required
                class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent transition-all bg-gray-50/50 text-sm"
              />
            </div>
            
            <button 
              type="submit"
              class="w-full bg-[#40c4eb] text-white py-5 px-6 rounded-2xl font-black text-lg shadow-[0_15px_30px_rgba(64,196,235,0.3)] hover:bg-[#091f41] hover:translate-y-[-4px] transition-all duration-300 uppercase tracking-wider"
            >
              SUBMIT FORM
            </button>
          </form>

          <!-- Trust indicators -->
          <div class="mt-4 pt-4 border-t border-gray-100 flex flex-wrap justify-center gap-4 text-xs text-gray-500">
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
              Secure Form
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              Fast Response
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              No Spam
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
