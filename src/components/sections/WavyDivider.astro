---
interface Props {
  topColor?: string;
  bottomColor?: string;
  flip?: boolean;
}

const { 
  topColor = 'transparent', 
  bottomColor = 'var(--brand-secondary)', 
  flip = false 
} = Astro.props;
---

<div class={`wavy-divider ${flip ? 'flip' : ''}`} style={`background-color: ${topColor}`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
    <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" style={`fill: ${bottomColor}`}></path>
  </svg>
</div>

<style>
  .wavy-divider {
    width: 100%;
    overflow: hidden;
    line-height: 0;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .wavy-divider svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 60px;
    margin-bottom: -1px;
  }

  .wavy-divider.flip {
    transform: rotate(180deg);
  }

  @media (min-width: 768px) {
    .wavy-divider svg {
      height: 80px;
    }
  }

  @media (min-width: 1024px) {
    .wavy-divider svg {
      height: 100px;
    }
  }
</style>
