---
import { getLocationText } from "@/config/site"

interface Review {
  name: string;
  time: string;
  content: string;
  readMoreHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  reviews: Review[];
  verifiedBy?: string;
}

const { badge: raw_badge = "GOOGLE REVIEW", title: raw_title, description: raw_description, reviews: rawReviews, verifiedBy = "Verified by Trustindex" } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const reviews = rawReviews.map(r => ({
  ...r,
  content: getLocationText(r.content),
}));
---

<section class="py-16 md:py-24 bg-brand-tertiary/30">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12" data-animate="fade-up">
      <span class="inline-block text-sm font-semibold text-accent uppercase tracking-wide border-b-2 border-accent pb-1">{badge}</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-4">{title}</h2>
      {description && <p class="text-muted-foreground max-w-3xl mx-auto" set:html={description} />}
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6" data-animate-stagger>
      {reviews.map((review) => (
        <div class="bg-card border rounded-lg p-6 hover:border-accent/30 transition-colors shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full bg-brand-secondary flex items-center justify-center">
              <span class="text-lg font-semibold text-white">{review.name.split(' ').map(n => n[0]).join('')}</span>
            </div>
            <div>
              <p class="font-semibold">{review.name}</p>
              <p class="text-xs text-muted-foreground">{review.time}</p>
            </div>
          </div>
          <div class="flex text-yellow-500 mb-3">
            ★★★★★
          </div>
          <p class="text-sm text-muted-foreground mb-3 line-clamp-4" set:html={review.content} />
          {review.readMoreHref && (
            <a href={review.readMoreHref} class="text-sm text-accent font-medium hover:underline">
              Read more
            </a>
          )}
        </div>
      ))}
    </div>
    
    {verifiedBy && (
      <div class="text-center mt-8">
        <span class="inline-flex items-center gap-2 text-sm text-muted-foreground">
          <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          {verifiedBy}
        </span>
      </div>
    )}
  </div>
</section>
