---
import { Droplet, Star } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface Review {
  name: string;
  time: string;
  content: string;
  readMoreHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  reviews: Review[];
  verifiedBy?: string;
}

const { badge: raw_badge = "GOOGLE REVIEW", title: raw_title, description: raw_description, reviews: rawReviews, verifiedBy = "Verified by Trustindex" } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const reviews = rawReviews.map(r => ({
  ...r,
  content: getLocationText(r.content),
}));
---

<section class="py-12 md:py-16 bg-[#f1fbfe]">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12" data-animate="fade-up">
      {badge && (
        <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-3" style="color: #40c4eb; border: 1.5px solid rgba(64,196,235,0.6); background-color: rgba(64,196,235,0.12);">
          <Droplet class="w-3 h-3 flex-shrink-0" />
          {badge}
        </span>
      )}
      <h2 class="font-extrabold mb-4" style="font-size: 43px;">{title}</h2>
      {description && <p class="text-brand-primary/80 max-w-7xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />}
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6" data-animate-stagger>
      {reviews.map((review) => {
        const initials = review.name.split(' ').map(n => n[0]).join('').toUpperCase();
        return (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 flex flex-col h-full">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 font-bold text-lg border border-slate-100">
                  {initials}
                </div>
                <div>
                  <h4 class="font-bold text-[#091f41] leading-none mb-1">{review.name}</h4>
                  <p class="text-xs text-slate-400">{review.time}</p>
                </div>
              </div>
              <div class="w-6 h-6 shrink-0">
                <svg viewBox="0 0 24 24" class="w-full h-full">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
            </div>
            
            <div class="flex gap-0.5 mb-4">
              {[...Array(5)].map((_, i) => (
                <Star class="w-4 h-4 text-yellow-400 fill-yellow-400" />
              ))}
            </div>

            <div class="flex-1 mb-4 text-[#091f41] leading-relaxed text-[15px]">
              <p class="whitespace-pre-wrap line-clamp-5" set:html={review.content} />
            </div>
            
            <div class="text-[11px] font-bold uppercase tracking-wider text-slate-300">
              Verified Google Review
            </div>
          </div>
        );
      })}
    </div>
    
    {verifiedBy && (
      <div class="text-center mt-8">
        <span class="inline-flex items-center gap-2 text-sm text-clay-muted">
          <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          {verifiedBy}
        </span>
      </div>
    )}
  </div>
</section>
