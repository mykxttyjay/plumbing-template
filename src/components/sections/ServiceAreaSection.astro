---
import { getLocationText, processLocationArray } from "@/config/site"

interface Props {
  title: string;
  description: string;
  areas?: string[];
  mapImage?: string;
  mapEmbed?: string;
  mapAddress?: string;
  variant?: "full" | "compact";
  buttonText?: string;
  buttonHref?: string;
}

const { 
  title: rawTitle, 
  description: rawDescription, 
  areas: rawAreas, 
  mapImage, 
  mapEmbed, 
  mapAddress: rawMapAddress,
  variant = "full",
  buttonText: rawButtonText = "SERVICE AREAS",
  buttonHref = "/service-areas"
} = Astro.props;

// Process all text through getLocationText
const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const areas = rawAreas ? processLocationArray(rawAreas) : undefined;
const mapAddress = rawMapAddress ? getLocationText(rawMapAddress) : undefined;
const buttonText = getLocationText(rawButtonText);

// Generate Google Maps embed URL from address if mapEmbed not provided
const getMapEmbedUrl = (address: string) => {
  const encodedAddress = encodeURIComponent(address);
  return `https://www.google.com/maps?q=${encodedAddress}&output=embed`;
};

const embedUrl = mapEmbed || (mapAddress ? getMapEmbedUrl(mapAddress) : null);
---

{variant === "compact" ? (
  <section class="py-12 md:py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="order-2 md:order-1">
          {embedUrl ? (
            <div class="aspect-[4/3] rounded-clay overflow-hidden shadow-clay-card">
              <iframe
                src={embedUrl}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Service Area Map"
              ></iframe>
            </div>
          ) : mapImage ? (
            <img src={mapImage} alt="Service Area Map" class="rounded-clay w-full shadow-clay-card" />
          ) : (
            <div class="aspect-[4/3] bg-muted rounded-clay flex items-center justify-center shadow-clay-card">
              <span class="text-clay-muted">Map - Service Area</span>
            </div>
          )}
        </div>
        
        <div class="order-1 md:order-2 text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-extrabold mb-4">{title}</h2>
          <p class="text-clay-muted mb-6" set:html={description} />
          <a href={buttonHref} class="inline-flex items-center justify-center rounded-clay-sm bg-primary text-primary-foreground px-6 py-3 font-semibold shadow-clay-button clay-squish hover:shadow-clay-button-hover hover:-translate-y-1 transition-all">
            {buttonText}
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="py-12 md:py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <div data-animate="fade-right">
          <h2 class="text-3xl md:text-4xl font-extrabold mb-6">{title}</h2>
          <p class="text-clay-muted mb-8" set:html={description} />
          
          {areas && areas.length > 0 && (
            <>
              <h3 class="text-xl font-extrabold mb-4">Areas We Serve</h3>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm">
                {areas.map((area) => (
                  <span class="text-clay-muted hover:text-accent transition-colors cursor-default flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/60"></span>
                    {area}
                  </span>
                ))}
              </div>
            </>
          )}
        </div>
        
        <div data-animate="fade-left">
          {embedUrl ? (
            <div class="aspect-[4/3] rounded-clay overflow-hidden shadow-clay-card">
              <iframe
                src={embedUrl}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Service Area Map"
              ></iframe>
            </div>
          ) : mapImage ? (
            <img src={mapImage} alt="Service Area Map" class="rounded-clay w-full shadow-clay-card" />
          ) : (
            <div class="aspect-[4/3] bg-muted rounded-clay flex items-center justify-center shadow-clay-card">
              <span class="text-clay-muted">Map - Service Area</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}
