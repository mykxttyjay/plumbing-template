---
import { getLocationText, processLocationArray } from "@/config/site"

interface Props {
  title: string;
  description: string;
  areas?: string[];
  mapImage?: string;
  mapEmbed?: string;
  mapAddress?: string;
  variant?: "full" | "compact";
  buttonText?: string;
  buttonHref?: string;
}

const { 
  title: rawTitle, 
  description: rawDescription, 
  areas: rawAreas, 
  mapImage, 
  mapEmbed, 
  mapAddress: rawMapAddress,
  variant = "full",
  buttonText: rawButtonText = "SERVICE AREAS",
  buttonHref = "/service-areas"
} = Astro.props;

// Process all text through getLocationText
const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const areas = rawAreas ? processLocationArray(rawAreas) : undefined;
const mapAddress = rawMapAddress ? getLocationText(rawMapAddress) : undefined;
const buttonText = getLocationText(rawButtonText);

// Generate Google Maps embed URL from address if mapEmbed not provided
const getMapEmbedUrl = (address: string) => {
  const encodedAddress = encodeURIComponent(address);
  return `https://www.google.com/maps?q=${encodedAddress}&output=embed`;
};

const embedUrl = mapEmbed || (mapAddress ? getMapEmbedUrl(mapAddress) : null);
---

{variant === "compact" ? (
  <section class="py-12 md:py-16 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        {/* Map Container */}
        <div class="order-2 md:order-1" data-animate="fade-right">
          <div class="relative">
            {embedUrl ? (
              <div class="aspect-[4/3] rounded-[2rem] overflow-hidden border-4 border-brand-primary/5 bg-muted/20">
                <iframe
                  src={embedUrl}
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Service Area Map"
                ></iframe>
              </div>
            ) : mapImage ? (
              <img src={mapImage} alt="Service Area Map" class="rounded-[2rem] w-full border-4 border-brand-primary/5 bg-muted/20" />
            ) : (
              <div class="aspect-[4/3] bg-muted rounded-[2rem] flex items-center justify-center shadow-inner">
                <span class="text-brand-primary/40 font-bold uppercase tracking-widest text-xs">Service Map Unavailable</span>
              </div>
            )}
          </div>
        </div>
        
        {/* Text Content */}
        <div class="order-1 md:order-2 text-center md:text-left" data-animate="fade-left">
          <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-6" style="color: #40c4eb; border: 1.5px solid rgba(64,196,235,0.6); background-color: rgba(64,196,235,0.12);">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Local Service
          </span>
          
          <h2 class="font-black mb-6 leading-tight" style="font-size: 40px;" set:html={title} />
          <div class="text-brand-primary/70 mb-10 leading-relaxed space-y-4" style="font-size: 18px;" set:html={description} />
          
          <a href={buttonHref} class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-[#091f41] text-white px-8 py-4 font-bold shadow-xl hover:bg-[#40c4eb] transition-all duration-500">
            <span>{buttonText}</span>
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="py-12 md:py-16 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20">
        <div data-animate="fade-right">
          <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-6" style="color: #40c4eb; border: 1.5px solid rgba(64,196,235,0.6); background-color: rgba(64,196,235,0.12);">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Service Locations
          </span>

          <h2 class="font-black mb-6 leading-tight max-w-[850px]" style="font-size: 40px;" set:html={title} />
          <div class="text-brand-primary/70 mb-10 leading-relaxed" style="font-size: 18px;" set:html={description} />
          
          {areas && areas.length > 0 && (
            <div class="p-8 rounded-[2rem] bg-muted/30 border border-brand-primary/5">
              <h3 class="text-xl font-black text-brand-primary mb-6 flex items-center gap-3">
                <span class="w-1.5 h-6 bg-[#40c4eb] rounded-full"></span>
                Areas We Serve
              </h3>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-3 gap-x-4 text-sm">
                {areas.map((area) => (
                  <span class="text-brand-primary/60 hover:text-[#40c4eb] transition-colors cursor-default flex items-center gap-2 font-medium">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#40c4eb]/40 group-hover:bg-[#40c4eb]"></span>
                    {area}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
        
        <div data-animate="fade-left" class="h-full lg:pt-[72px]">
          <div class="relative h-full">
            {embedUrl ? (
              <div class="h-full min-h-[450px] rounded-[2rem] overflow-hidden border-4 border-brand-primary/5 bg-muted/20 shadow-sm">
                <iframe
                  src={embedUrl}
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Service Area Map"
                ></iframe>
              </div>
            ) : mapImage ? (
              <img src={mapImage} alt="Service Area Map" class="h-full min-h-[450px] object-cover rounded-[2rem] w-full border-4 border-brand-primary/5 bg-muted/20 shadow-sm" />
            ) : (
              <div class="h-full min-h-[450px] bg-muted rounded-[2rem] flex items-center justify-center shadow-inner">
                <span class="text-brand-primary/40 font-bold uppercase tracking-widest text-xs">Service Map Unavailable</span>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
)}
