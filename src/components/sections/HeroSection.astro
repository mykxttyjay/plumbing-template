---
import { ArrowUpRight, Droplet, ArrowRight } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface HeroSlide {
  title: string;
  subtitle?: string;
  image: string;
  promoTitle?: string;
  promoText?: string;
  promoImage?: string;
  buttonText?: string;
}

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  slides?: HeroSlide[];
  variant?: "default" | "subpage" | "category";
}

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  slides?: HeroSlide[];
  variant?: "default" | "subpage" | "category";
  trustIndicators?: string[];
}

const {
  badge,
  title: rawTitle,
  subtitle: rawSubtitle,
  buttonText: rawButtonText = "Call Now",
  buttonHref: rawButtonHref = "tel:{phoneRaw}",
  image,
  slides: rawSlides = [],
  variant = "default",
  trustIndicators: rawTrustIndicators,
} = Astro.props;

// Process all text placeholders
const title = rawTitle ? getLocationText(rawTitle) : "";
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const badge_processed = badge ? getLocationText(badge) : undefined;
const buttonText = getLocationText(rawButtonText);
const buttonHref = getLocationText(rawButtonHref);
const trustIndicators = rawTrustIndicators ? rawTrustIndicators.map(t => getLocationText(t)) : undefined;

// Process slide text
const slides = rawSlides.map(slide => ({
  ...slide,
  title: getLocationText(slide.title),
  subtitle: slide.subtitle ? getLocationText(slide.subtitle) : undefined,
  promoTitle: slide.promoTitle ? getLocationText(slide.promoTitle) : undefined,
  promoText: slide.promoText ? getLocationText(slide.promoText) : undefined,
  promoImage: slide.promoImage || undefined,
  buttonText: slide.buttonText ? getLocationText(slide.buttonText) : undefined,
}));

const hasSlideshow = slides.length > 1;
---

{variant === "subpage" ? (
  <section class="subpage-hero relative bg-primary overflow-hidden">

    <div class="container mx-auto px-4 relative z-10">
      <div class="grid md:grid-cols-2 min-h-[300px] md:min-h-[350px]">
        <div class="relative flex items-center py-10 md:py-14 pr-8">
          <div class="pt-2">
            {badge_processed && (
              <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-5" style="border: 1.5px solid currentColor; background-color: rgba(64, 196, 235, 0.08);">
                <Droplet class="w-3 h-3 flex-shrink-0" />
                {badge_processed}
              </span>
            )}

            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-primary-foreground mb-5 leading-tight">
              {title}
            </h1>
            {subtitle && (
              <p class="text-lg text-primary-foreground/90 mb-8 max-w-lg leading-relaxed" set:html={subtitle} />
            )}

            <div class="flex flex-wrap items-center gap-4">
              <a href={buttonHref} class="group/btn inline-flex items-center justify-center gap-3 rounded-2xl bg-[#40c4eb] text-white px-8 py-4 font-bold shadow-xl hover:bg-white hover:text-[#091f41] transition-all duration-500 text-[16px] no-underline">
                <span>{buttonText}</span>
                <ArrowRight class="w-5 h-5 transition-transform" />
              </a>
            </div>

            {/* Trust indicators row */}
            {trustIndicators && trustIndicators.length > 0 && (
              <div class="flex flex-wrap gap-x-5 gap-y-2 mt-8">
                {trustIndicators.map((indicator) => (
                  <span class="inline-flex items-center gap-2 text-sm text-primary-foreground/60">
                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--brand-highlight, #45f9ff);"></span>
                    {indicator}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
        <div class="hidden md:block relative -mr-4 md:-mr-[calc((100vw-100%)/2+1rem)]" style="clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);">
          {image ? (
            <Fragment>
              <img src={image} alt={title} class="absolute inset-0 w-full h-full object-cover" />
              {/* Teal accent line at the bottom of the image */}
              <div class="absolute bottom-0 left-0 right-0 h-[6px] bg-[#40c4eb]"></div>
            </Fragment>
          ) : (
            <div class="absolute inset-0 bg-muted flex items-center justify-center">
              <span class="text-muted-foreground">Hero Image</span>
            </div>
          )}
        </div>
      </div>
    </div>

    {/* Bottom teal accent line spanning full width */}
    <div class="absolute bottom-0 left-0 right-0 h-[3px] z-20 bg-[var(--brand-highlight,#45f9ff)]"></div>
  </section>
) : variant === "category" ? (
  <!-- Category hero -->
  <section class="relative bg-muted/30 py-20 md:py-32">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="text-center md:text-left">
          {badge_processed && (
            <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide mb-6" style="border: 1.5px solid currentColor; background-color: rgba(64, 196, 235, 0.08);">
              <Droplet class="w-3 h-3 flex-shrink-0" />
              {badge_processed}
            </span>
          )}
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            {title}
          </h1>
          {subtitle && (
            <p class="text-xl text-primary/85 mb-8" set:html={subtitle} />
          )}
          <a href={buttonHref} class="inline-flex items-center justify-center gap-3 rounded-full bg-[#091f41] text-white px-10 py-4 text-lg font-bold shadow-xl hover:bg-accent hover:-translate-y-1 transition-all duration-300 group no-underline">
            <span>{buttonText}</span>
            <ArrowRight class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" />
          </a>
        </div>
        <div class="hidden md:block">
          {image ? (
            <img src={image} alt={title} class="rounded-clay w-full aspect-video object-cover shadow-clay-card" />
          ) : (
            <div class="aspect-video bg-muted rounded-lg flex items-center justify-center">
              <span class="text-muted-foreground">Hero Image</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
) : slides.length > 0 ? (
  <!-- Slideshow hero -->
  <section class="hero-slideshow relative overflow-hidden bg-primary" style="min-height: 540px;">
    <!-- Background images -->
    {slides.map((slide, i) => (
      <div
        class:list={[
          "hero-bg absolute inset-0 transition-opacity duration-1000 ease-in-out",
          i === 0 ? "opacity-100" : "opacity-0"
        ]}
        data-bg-index={i}
      >
        <img
          src={slide.image}
          alt={slide.title}
          class="absolute inset-0 w-full h-full object-cover"
          loading={i === 0 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "low"}
          decoding="async"
        />
        <div class="absolute inset-0" style="background-color: rgba(199, 215, 234, 0.3);"></div>
        <div class="absolute inset-0" style="background-color: rgba(30, 96, 170, 0.5);"></div>
      </div>
    ))}

    <!-- Content layer -->
    <div class="relative z-10 container mx-auto px-4 py-16 md:py-24 lg:py-28">
      <div class="grid md:grid-cols-5 gap-8 lg:gap-12 items-center min-h-[380px]">

        <!-- Left: text content -->
        <div class="md:col-span-3 relative" style="min-height: 260px;">
          {slides.map((slide, i) => (
            <div
              class:list={[
                "hero-text absolute inset-0 flex flex-col justify-center transition-all duration-700",
                i === 0 ? "opacity-100 translate-y-0" : "opacity-0 translate-y-4"
              ]}
              data-text-index={i}
            >
              <h1 class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold text-primary-foreground mb-4 leading-tight">
                {slide.title}
              </h1>
              {slide.subtitle && (
                <p class="text-lg md:text-xl text-primary-foreground/90 mb-8 max-w-xl">
                  {slide.subtitle}
                </p>
              )}
              <div>
                <a href={buttonHref} class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-[#40c4eb] text-white px-8 py-4 font-bold shadow-xl hover:bg-white hover:text-[#091f41] transition-all duration-500 text-[16px] no-underline">
                  <span>{slide.buttonText || buttonText}</span>
                  <ArrowRight class="w-5 h-5 transition-transform" />
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Right: promo box -->
        <div class="md:col-span-2 hidden md:flex justify-center md:justify-center relative" style="min-height: 260px;">
          {slides.map((slide, i) => (
            slide.promoTitle && (
              <div
                class:list={[
                  "hero-promo absolute inset-0 flex items-center justify-center md:justify-center transition-all duration-700",
                  i === 0 ? "opacity-100 scale-100" : "opacity-0 scale-95"
                ]}
                data-promo-index={i}
              >
                <div class="promo-card relative w-full max-w-[340px]">
                  <div
                    class="promo-glow absolute -inset-3 rounded-[1.75rem] blur-2xl"
                    style="background: var(--brand-highlight, var(--brand-secondary));"
                    aria-hidden="true"
                  ></div>

                  <article
                    class="hero-coupon-ticket relative overflow-hidden rounded-clay border border-white/25 bg-white text-center shadow-clay-card ring-1 ring-black/[0.05]"
                  >
                    <div
                      class="h-1 w-full bg-[var(--brand-secondary)]"
                      aria-hidden="true"
                    ></div>

                    <header
                      class="border-b px-5 py-3.5"
                      style="border-color: color-mix(in oklab, var(--brand-primary) 14%, transparent); background: color-mix(in oklab, var(--brand-quaternary) 90%, white);"
                    >
                      <p class="mb-0 text-xs font-bold uppercase tracking-[0.2em]" style="color: var(--brand-primary);">
                        <span class="relative inline-flex items-center gap-1.5">
                          <span class="relative flex h-1.5 w-1.5">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full" style="background: var(--brand-accent); opacity: 0.6;"></span>
                            <span class="relative inline-flex h-1.5 w-1.5 rounded-full" style="background: var(--brand-accent);"></span>
                          </span>
                          Limited Offer
                        </span>
                      </p>
                    </header>

                    <div class="relative px-6 pb-5 pt-5 text-center">
                      <div
                        class="pointer-events-none absolute -right-10 -top-10 h-36 w-36 rounded-full opacity-[0.07]"
                        style="background: var(--brand-secondary);"
                        aria-hidden="true"
                      ></div>

                      {slide.promoImage && (
                        <div class="relative z-[1] mb-4 h-24 w-full overflow-hidden rounded-clay-sm shadow-clay-button">
                          <img src={slide.promoImage} alt="" class="h-full w-full object-cover" loading="lazy" />
                        </div>
                      )}

                      <h2 class="promo-coupon-title relative z-[1] mb-2 text-3xl font-black leading-tight md:text-4xl" style="color: var(--brand-secondary);">
                        Special Deal
                      </h2>
                      <p class="relative z-[1] mb-4 text-xs" style="color: var(--brand-primary); opacity: 0.7;">Redeem &amp; Save Today</p>

                      <div
                        class="promo-value-box relative z-[1] mb-4 inline-flex items-baseline gap-1 rounded-clay-sm px-6 py-2.5 shadow-clay-button"
                        style="background: var(--brand-primary);"
                      >
                        <span class="promo-value text-3xl font-black leading-none tracking-tight text-white md:text-4xl">
                          {slide.promoTitle}
                        </span>
                      </div>

                      <p class="relative z-[1] mb-0 text-sm font-medium leading-relaxed" style="color: var(--brand-primary);">
                        {slide.promoText}
                      </p>
                    </div>

                    <div
                      class="mx-5 border-t-2 border-dashed py-1"
                      style="border-color: color-mix(in oklab, var(--brand-secondary) 42%, transparent);"
                      aria-hidden="true"
                    ></div>

                    <footer
                      class="px-6 py-3.5 text-center"
                      style="background: color-mix(in oklab, var(--brand-quaternary) 94%, white);"
                    >
                      <p class="text-xs font-semibold italic" style="color: var(--brand-accent);">
                        * Call now to redeem
                      </p>
                    </footer>
                  </article>
                </div>
              </div>
            )
          ))}
        </div>
      </div>

      <!-- Progress bar indicators -->
      {hasSlideshow && (
        <div class="hero-progress flex gap-3 mt-8 max-w-xs">
          {slides.map((_, i) => (
            <button
              type="button"
              class="hero-progress-bar group relative h-1 flex-1 rounded-full bg-primary-foreground/20 overflow-hidden cursor-pointer"
              data-progress-index={i}
              aria-label={`Go to slide ${i + 1}`}
            >
              <span
                class:list={[
                  "hero-fill absolute inset-y-0 left-0 bg-accent rounded-full",
                  i === 0 ? "w-0 animate-hero-fill" : "w-0"
                ]}
                data-fill-index={i}
              ></span>
            </button>
          ))}
        </div>
      )}
    </div>
  </section>
) : (
  <!-- Static single-image hero (original) -->
  <section class="relative bg-muted/30 py-20 md:py-32">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="text-center md:text-left">
          {badge_processed && (
            <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide mb-6" style="border: 1.5px solid currentColor; background-color: rgba(64, 196, 235, 0.08);">
              <Droplet class="w-3 h-3 flex-shrink-0" />
              {badge_processed}
            </span>
          )}
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            {title}
          </h1>
          {subtitle && (
            <p class="text-xl text-primary/85 mb-8" set:html={subtitle} />
          )}
          <a href={buttonHref} class="inline-flex items-center justify-center gap-3 rounded-full bg-[#091f41] text-white px-10 py-4 text-lg font-bold shadow-xl hover:bg-accent hover:-translate-y-1 transition-all duration-300 group no-underline">
            <span>{buttonText}</span>
            <ArrowRight class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" />
          </a>
        </div>
        <div class="hidden md:block">
          {image ? (
            <img src={image} alt={title} class="rounded-clay w-full shadow-clay-card" />
          ) : (
            <div class="aspect-video bg-muted rounded-lg flex items-center justify-center">
              <span class="text-muted-foreground">Hero Image</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .subpage-hero-cta {
    position: relative;
  }
  .subpage-hero-cta:hover {
    transform: translateY(-2px);
  }

  @keyframes hero-fill {
    from { width: 0%; }
    to { width: 100%; }
  }
  .animate-hero-fill {
    animation: hero-fill 5s linear forwards;
    background-color: var(--brand-accent);
  }

  .promo-value {
    color: #fff;
    -webkit-text-fill-color: #fff;
  }

  /* Coupon title color pulse */
  .promo-coupon-title {
    animation: coupon-title-pulse 3s ease-in-out infinite;
  }

  @keyframes coupon-title-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  /* Value box subtle scale pulse */
  .promo-value-box {
    animation: value-box-pulse 2s ease-in-out infinite;
  }

  @keyframes value-box-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.02); }
  }

  /* Float animation for the card */
  .promo-card {
    animation: promo-float 5s ease-in-out infinite;
  }

  @keyframes promo-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  /* Pulsing outer glow */
  .promo-glow {
    animation: promo-pulse 3.5s ease-in-out infinite;
  }

  @keyframes promo-pulse {
    0%, 100% { opacity: 0.12; transform: scale(1); }
    50% { opacity: 0.32; transform: scale(1.04); }
  }

  @media (prefers-reduced-motion: reduce) {
    .promo-card,
    .promo-glow,
    .promo-coupon-title,
    .promo-value-box,
    .promo-value {
      animation: none !important;
    }
    .promo-value {
      color: #fff;
      -webkit-text-fill-color: #fff;
      background: none;
    }
  }
</style>

{hasSlideshow && (
  <script>
    function initHeroSlideshow() {
      const bgs = document.querySelectorAll<HTMLElement>('.hero-bg');
      const texts = document.querySelectorAll<HTMLElement>('.hero-text');
      const promos = document.querySelectorAll<HTMLElement>('.hero-promo');
      const fills = document.querySelectorAll<HTMLElement>('.hero-fill');
      const bars = document.querySelectorAll<HTMLButtonElement>('.hero-progress-bar');

      if (bgs.length < 2) return;

      let current = 0;
      const total = bgs.length;
      const duration = 5000;
      let timer: ReturnType<typeof setTimeout>;

      function goTo(index: number) {
        // Background crossfade
        bgs.forEach((bg, i) => {
          bg.classList.toggle('opacity-100', i === index);
          bg.classList.toggle('opacity-0', i !== index);
        });

        // Text slide
        texts.forEach((t, i) => {
          if (i === index) {
            t.classList.remove('opacity-0', 'translate-y-4');
            t.classList.add('opacity-100', 'translate-y-0');
          } else {
            t.classList.remove('opacity-100', 'translate-y-0');
            t.classList.add('opacity-0', 'translate-y-4');
          }
        });

        // Promo box
        promos.forEach((p, i) => {
          if (i === index) {
            p.classList.remove('opacity-0', 'scale-95');
            p.classList.add('opacity-100', 'scale-100');
          } else {
            p.classList.remove('opacity-100', 'scale-100');
            p.classList.add('opacity-0', 'scale-95');
          }
        });

        // Progress fills
        fills.forEach((f, i) => {
          f.classList.remove('animate-hero-fill');
          f.style.width = i < index ? '100%' : '0%';
          if (i === index) {
            // Force reflow to restart animation
            void f.offsetWidth;
            f.style.width = '';
            f.classList.add('animate-hero-fill');
          }
        });

        current = index;
      }

      function next() {
        goTo((current + 1) % total);
        scheduleNext();
      }

      function scheduleNext() {
        clearTimeout(timer);
        timer = setTimeout(next, duration);
      }

      // Click on progress bars
      bars.forEach((bar) => {
        bar.addEventListener('click', () => {
          const idx = Number(bar.dataset.progressIndex);
          goTo(idx);
          scheduleNext();
        });
      });

      // Start autoplay
      scheduleNext();
    }

    document.addEventListener('astro:page-load', initHeroSlideshow);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroSlideshow);
    } else {
      initHeroSlideshow();
    }
  </script>
)}
