---
import { ArrowRight, Droplet, Check } from '@lucide/astro';
import { getLocationText } from "@/config/site"

interface FeatureItem {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  featuresTitle?: string;
  features?: FeatureItem[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  image?: string;
  imageAlt?: string;
}

const { 
  badge: raw_badge, 
  title: raw_title, 
  titleHighlight,
  description: raw_description, 
  featuresTitle,
  features = [], 
  buttonText, 
  buttonHref,
  imagePosition = "left",
  image,
  imageAlt = "Section image"
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const titleHighlightProcessed = titleHighlight ? getLocationText(titleHighlight) : titleHighlight;
const description = raw_description ? getLocationText(raw_description) : raw_description;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
---

<section class="py-12 md:py-16 bg-[#f1fbfe] relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    {/* Header - centered above the two columns */}
    <div class="text-center mb-16" data-animate="fade-up">
      {badge && (
        <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center mb-6" style="border: 1.5px solid currentColor; background-color: rgba(64, 196, 235, 0.08);">
          <Droplet class="w-3 h-3 flex-shrink-0" />
          {badge}
        </span>
      )}
      <h2 class="font-black mb-6 leading-tight text-brand-primary" style="font-size: 43px;">
        {title}{" "}
        {titleHighlightProcessed && (
          <span class="text-accent">{titleHighlightProcessed}</span>
        )}
      </h2>
      <p class="text-brand-primary/80 max-w-5xl mx-auto leading-relaxed" style="font-size: 18px;" set:html={description} />
    </div>

    {/* Two column layout */}
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class={`order-2 ${imagePosition === "left" ? "md:order-2" : "md:order-1"}`} data-animate="fade-up">
        {features.length > 0 && (
          <div class="space-y-8">
            {featuresTitle && (
              <h3 class="text-2xl font-black text-brand-primary uppercase tracking-wider">{featuresTitle}</h3>
            )}
            <ul class="space-y-6">
              {features.map((feature) => (
                <li class="flex gap-4 group">
                  <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-white text-accent flex items-center justify-center shadow-[0_10px_25px_rgba(0,0,0,0.05)] group-hover:bg-accent group-hover:text-white transition-all duration-500">
                    <Check class="w-6 h-6" />
                  </div>
                  <div>
                    <h4 class="text-lg font-black text-brand-primary leading-tight mb-1">{feature.title}</h4>
                    <p class="text-brand-primary/60 text-sm leading-relaxed" set:html={feature.description} />
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}

        {buttonText && buttonHref && (
          <div class="pt-10">
            <a href={buttonHref} class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-[#091f41] text-white px-8 py-4 font-bold shadow-xl hover:bg-accent transition-all duration-500 hover:translate-y-[-4px]">
              <span>{buttonText}</span>
              <ArrowRight class="w-5 h-5 transition-transform group-hover:translate-x-1" />
            </a>
          </div>
        )}
      </div>

      <div class={`${imagePosition === "left" ? "order-1 md:order-1" : "order-1 md:order-2"}`} data-animate={imagePosition === "left" ? "fade-right" : "fade-left"}>
        <div class="relative group">
          <div class={`absolute -inset-4 md:-inset-6 bg-accent/10 rounded-[2.5rem] transform z-[-1] transition-transform duration-700 ${imagePosition === "left" ? "-rotate-3" : "rotate-3"}`}></div>
          {image ? (
            <div class="relative rounded-[2rem] overflow-hidden shadow-[0_32px_64px_-15px_rgba(0,0,0,0.5)]">
              <img src={image} alt={imageAlt} class="w-full h-full object-cover aspect-[4/3]" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>
          ) : (
            <div class="aspect-video bg-muted rounded-[2rem] flex items-center justify-center shadow-inner">
              <span class="text-brand-primary/30 font-black uppercase tracking-widest text-xs">Image Placeholder</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
