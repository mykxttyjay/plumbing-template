---
import { getLocationText } from "@/config/site"
import { ChevronRight } from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  imageAlt?: string;
}

const { 
  title: raw_title, 
  description: raw_description, 
  buttonText = "APPLY TODAY", 
  buttonHref = "/contact",
  image,
  imageAlt = "Join our team"
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
---

<section class="py-12 md:py-16 bg-[#091f41] text-white relative overflow-hidden">
  <!-- Dynamic Background Effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[40%25] -right-[10%25] w-[600px] h-[600px] bg-[#40c4eb]/10 rounded-full blur-[120px]"></div>
    <div class="absolute -bottom-[40%25] -left-[10%25] w-[500px] h-[500px] bg-accent/5 rounded-full blur-[100px]"></div>
    <div class="absolute inset-0 bg-[url('/images/noise.png')] opacity-[0.03] mix-blend-overlay"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="text-white" data-animate="fade-right">
        <h2 class="font-black mb-6 leading-tight" style="font-size: 43px;">{title}</h2>
        {description && (
          <p class="text-white/80 mb-10 max-w-2xl leading-relaxed" style="font-size: 18px;" set:html={description} />
        )}
        
        <div class="flex flex-wrap gap-5">
          <a 
            href={buttonHref} 
            class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-accent text-white px-8 py-5 text-xl font-black shadow-[0_20px_40px_rgba(64,196,235,0.2)] hover:bg-white hover:text-[#091f41] transition-all duration-500 hover:translate-y-[-4px]"
          >
            <span>{buttonText}</span>
            <ChevronRight class="w-6 h-6 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
      </div>

      <div class="relative" data-animate="fade-left">
        <div class="absolute -inset-4 bg-accent/20 rounded-[2.5rem] blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        {image ? (
          <div class="relative rounded-[2.5rem] overflow-hidden shadow-[0_32px_64px_-15px_rgba(0,0,0,0.5)] border-4 border-white/10">
            <img 
              src={image} 
              alt={imageAlt} 
              class="w-full h-full object-cover aspect-[4/3] md:aspect-auto"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#091f41]/40 to-transparent"></div>
          </div>
        ) : (
          <div class="aspect-square bg-white/5 rounded-[2.5rem] border-2 border-dashed border-white/20 flex items-center justify-center">
            <span class="text-white/30 font-black">Careers Image</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
