---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  imageAlt?: string;
}

const { 
  title: raw_title, 
  description: raw_description, 
  buttonText = "APPLY TODAY", 
  buttonHref = "/contact",
  image,
  imageAlt = "Join our team"
} = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const description = raw_description ? getLocationText(raw_description) : raw_description;
---

<section class="py-16 md:py-24 bg-primary">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div class="text-primary-foreground" data-animate="fade-right">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
        {description && (
          <p class="text-primary-foreground/80 mb-6 max-w-lg" set:html={description} />
        )}
        <a 
          href={buttonHref} 
          class="inline-flex items-center justify-center rounded-md bg-accent text-accent-foreground px-6 py-3 font-semibold hover:bg-accent/90 transition-colors"
        >
          {buttonText}
        </a>
      </div>
      <div class="flex justify-center md:justify-end" data-animate="fade-left">
        {image ? (
          <img 
            src={image} 
            alt={imageAlt} 
            class="rounded-lg max-w-sm w-full object-cover shadow-xl"
          />
        ) : (
          <div class="aspect-square max-w-sm w-full bg-primary-foreground/10 rounded-lg flex items-center justify-center">
            <span class="text-primary-foreground/50">Image</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
