---
import { Droplet } from '@lucide/astro';
import { getLocationText } from "@/config/site"


interface Props {
  badge?: string;
  title: string;
  images?: string[];
  columns?: number;
  instagramUrl?: string;
  paddingTop?: boolean;
}

const { badge: raw_badge = "Portfolio", title: raw_title, images = [], columns = 4, instagramUrl = "https://instagram.com", paddingTop = false } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const placeholderCount = images.length > 0 ? images.length : 8;
---

<section class={`${paddingTop ? "py-12 md:py-16" : "pb-12 md:pb-16"}`} style="background-color: #c2ecf9;">
  
  <div class="container mx-auto px-4">
    <div class="text-center mb-12" data-animate="fade-up">
      <span class="inline-flex items-center gap-2 text-accent text-sm font-semibold px-4 py-1.5 rounded-full uppercase tracking-wide justify-center" style="border: 1.5px solid currentColor; background-color: rgba(64, 196, 235, 0.08);">
        <Droplet class="w-3 h-3 flex-shrink-0" />
        {badge}
      </span>
      <h2 class="font-extrabold mt-2" style="font-size: 43px;">{title}</h2>
    </div>
    
    <div class={`grid grid-cols-2 md:grid-cols-3 lg:grid-cols-${columns} gap-4`} data-animate-stagger>
      {images.length > 0 ? (
        images.map((img, i) => (
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="aspect-square rounded-clay overflow-hidden cursor-pointer group relative shadow-clay-card clay-lift hover:shadow-clay-card-hover">
            <img src={img} alt={`${title} - project ${i + 1}`} class="w-full h-full object-cover group-hover:scale-105 group-hover:blur-[2px] transition-all" loading="lazy" />
            {/* Eye icon overlay */}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors flex items-center justify-center">
              <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            </div>
          </a>
        ))
      ) : (
        Array.from({ length: placeholderCount }).map((_, i) => (
          <div class="aspect-square bg-muted rounded-clay flex items-center justify-center shadow-clay-card">
            <span class="text-clay-muted text-sm">Project {i + 1}</span>
          </div>
        ))
      )}
    </div>
  </div>
</section>
