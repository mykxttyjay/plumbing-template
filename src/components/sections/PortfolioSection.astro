---
import { getLocationText } from "@/config/site"

interface Props {
  badge?: string;
  title: string;
  images?: string[];
  columns?: number;
}

const { badge: raw_badge = "Portfolio", title: raw_title, images = [], columns = 4 } = Astro.props;

// Process text placeholders
const title = raw_title ? getLocationText(raw_title) : raw_title;
const badge = raw_badge ? getLocationText(raw_badge) : raw_badge;
const placeholderCount = images.length > 0 ? images.length : 8;
---

<section class="py-16 md:py-24 bg-muted/30">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12" data-animate="fade-up">
      <span class="inline-block text-sm font-semibold text-accent uppercase tracking-wide border-b-2 border-accent pb-1">{badge}</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-4">{title}</h2>
    </div>
    
    <div class={`grid grid-cols-2 md:grid-cols-3 lg:grid-cols-${columns} gap-4`} data-animate-stagger>
      {images.length > 0 ? (
        images.map((img, i) => (
          <div class="aspect-square rounded-lg overflow-hidden">
            <img src={img} alt={`${title} - project ${i + 1}`} class="w-full h-full object-cover hover:scale-105 transition-transform ring-2 ring-transparent hover:ring-accent/50" loading="lazy" />
          </div>
        ))
      ) : (
        Array.from({ length: placeholderCount }).map((_, i) => (
          <div class="aspect-square bg-muted rounded-lg flex items-center justify-center">
            <span class="text-muted-foreground text-sm">Project {i + 1}</span>
          </div>
        ))
      )}
    </div>
  </div>
</section>
