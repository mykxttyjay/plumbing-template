---
import { Siren, Award } from "lucide-react"
import { getLocationText } from "@/config/site"

interface Feature {
  icon: "siren" | "award" | "phone" | "clock" | "shield" | "wrench";
  text: string;
}

interface Props {
  buttonText?: string;
  buttonHref?: string;
  phoneLabel?: string;
  phone?: string;
  features?: Feature[];
  borderColor?: string;
}

const { 
  buttonText: rawButtonText = "SCHEDULE NOW", 
  buttonHref = "/contact",
  phoneLabel: rawPhoneLabel = "Call or Text for Great Service",
  phone: rawPhone = "{phone}",
  features: rawFeatures = [
    { icon: "siren", text: "24/7 Emergency Service" },
    { icon: "award", text: "Experienced & Certified Technicians" }
  ],
  borderColor
} = Astro.props;

// Process text placeholders
const buttonText = getLocationText(rawButtonText);
const phoneLabel = getLocationText(rawPhoneLabel);
const phone = getLocationText(rawPhone);
const features = rawFeatures.map(f => ({ ...f, text: getLocationText(f.text) }));

const iconMap = {
  siren: Siren,
  award: Award
};
---

<section class="bg-primary text-primary-foreground cta-section-bg">
  <!-- Decorative accent line at top - full width -->
  <div class="cta-accent-top-full w-full h-1"></div>
  
  <div class="container mx-auto px-4 py-6 md:py-8">
    <!-- Contained Card Content -->
    <div class="cta-card-content relative" data-animate="fade-up">
      <!-- Plumber image -->
      <img
        src="/images/plumber.png"
        alt=""
        class="hidden lg:block absolute bottom-0 left-8 w-32 xl:w-40 z-10 pointer-events-none cta-plumber-img"
        aria-hidden="true"
      />
      
      <!-- Content -->
      <div class="relative grid md:grid-cols-2 gap-8 items-center lg:pl-48">
        <!-- Left side: Heading and Description -->
        <div class="space-y-4">
          <div>
            <p class="cta-phone-label text-sm font-semibold uppercase tracking-wider opacity-90 mb-2">
              {phoneLabel}
            </p>
            <a href={`tel:${phone}`} class="text-3xl md:text-4xl font-bold hover:underline inline-block mb-4">
              {phone}
            </a>
          </div>
          
          <!-- Features -->
          <div class="flex flex-col gap-3">
            {features.map((feature) => {
              const IconComponent = iconMap[feature.icon as keyof typeof iconMap];
              return (
                <div class="flex items-center gap-3">
                  {IconComponent && (
                    <div class="cta-icon-badge flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center">
                      <IconComponent className="cta-icon w-5 h-5" />
                    </div>
                  )}
                  <span class="text-base font-medium">{feature.text}</span>
                </div>
              );
            })}
          </div>
        </div>
        
        <!-- Right side: CTA Button -->
        <div class="flex items-center justify-center md:justify-end">
          <a 
            href={buttonHref} 
            class="cta-button inline-flex items-center justify-center rounded-full bg-accent text-accent-foreground px-10 py-5 text-lg font-bold transition-all duration-300 shadow-2xl"
          >
            {buttonText}
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Decorative accent line at bottom - full width -->
  <div class="cta-accent-bottom-full w-full h-1"></div>
</section>

<style>
  .cta-section-bg {
    position: relative;
  }
  
  .cta-accent-top-full {
    background: linear-gradient(90deg, var(--brand-highlight, #45f9ff), var(--brand-accent));
  }
  
  .cta-accent-bottom-full {
    background: linear-gradient(90deg, var(--brand-accent), var(--brand-highlight, #45f9ff));
  }
  
  .cta-plumber-img {
    bottom: -0.5rem;
  }
  
  .cta-phone-label {
    color: var(--brand-highlight, #45f9ff);
  }
  
  .cta-icon-badge {
    background: rgba(64, 196, 235, 0.15);
  }
  
  .cta-icon {
    color: var(--brand-highlight, #45f9ff);
  }
  
  .cta-button {
    box-shadow: 0 25px 50px -12px rgba(64, 196, 235, 0.4);
  }
  
  .cta-button:hover {
    background-color: #1e3a8a;
    color: white;
    transform: scale(1.05);
    box-shadow: 0 25px 50px -12px rgba(30, 58, 138, 0.4);
  }
</style>
