---
import { Siren, Award } from "lucide-react"
import { getLocationText } from "@/config/site"

interface Feature {
  icon: "siren" | "award" | "phone" | "clock" | "shield" | "wrench";
  text: string;
}

interface Props {
  buttonText?: string;
  buttonHref?: string;
  phoneLabel?: string;
  phone?: string;
  features?: Feature[];
  borderColor?: string;
}

const { 
  buttonText: rawButtonText = "SCHEDULE NOW", 
  buttonHref = "/contact",
  phoneLabel: rawPhoneLabel = "Call or Text for Great Service",
  phone: rawPhone = "{phone}",
  features: rawFeatures = [
    { icon: "siren", text: "24/7 Emergency Service" },
    { icon: "award", text: "Experienced & Certified Technicians" }
  ],
  borderColor
} = Astro.props;

// Process text placeholders
const buttonText = getLocationText(rawButtonText);
const phoneLabel = getLocationText(rawPhoneLabel);
const phone = getLocationText(rawPhone);
const features = rawFeatures.map(f => ({ ...f, text: getLocationText(f.text) }));

const iconMap = {
  siren: Siren,
  award: Award
};
---

<section class="bg-[#091f41] text-white relative overflow-hidden">
  <!-- Dynamic Background Effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[40%] -right-[10%] w-[600px] h-[600px] bg-[#40c4eb]/10 rounded-full blur-[120px]"></div>
    <div class="absolute -bottom-[40%] -left-[10%] w-[500px] h-[500px] bg-accent/5 rounded-full blur-[100px]"></div>
    <div class="absolute inset-0 bg-[url('/images/noise.png')] opacity-[0.03] mix-blend-overlay"></div>
  </div>

  <div class="container mx-auto px-4 py-10 md:py-12 relative z-10">
    <div class="cta-card-content relative" data-animate="fade-up">
      <!-- Plumber image with glow -->
      <div class="hidden lg:block absolute bottom-[-48px] left-4 w-48 xl:w-56 z-10 pointer-events-none">
        <div class="absolute inset-0 bg-[#40c4eb]/20 blur-3xl rounded-full"></div>
        <img
          src="/images/plumber.png"
          alt=""
          class="relative z-10 w-full drop-shadow-[0_20px_30px_rgba(0,0,0,0.5)] transition-transform duration-700 hover:scale-105"
          aria-hidden="true"
        />
      </div>
      
      <!-- Content Grid -->
      <div class="relative grid md:grid-cols-2 gap-10 items-center lg:pl-64">
        <!-- Left side: Contact Info and Features -->
        <div class="space-y-6">
          <div class="relative">
            <p class="text-[#40c4eb] text-sm font-extrabold uppercase tracking-[0.2em] mb-3">
              {phoneLabel}
            </p>
            <a href={`tel:${phone}`} class="group inline-flex items-center gap-4 text-4xl md:text-5xl font-black transition-all duration-300 hover:text-[#40c4eb]">
              {phone}
              <span class="w-12 h-12 rounded-full border-2 border-white/20 flex items-center justify-center group-hover:border-[#40c4eb] group-hover:bg-[#40c4eb] transition-all duration-300">
                <Siren className="w-6 h-6 text-white" />
              </span>
            </a>
          </div>
          
          <!-- Features Row -->
          <div class="flex flex-wrap gap-6 pt-2">
            {features.map((feature) => {
              const IconComponent = iconMap[feature.icon as keyof typeof iconMap];
              return (
                <div class="flex items-center gap-4 group/feat">
                  {IconComponent && (
                    <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover/feat:bg-[#40c4eb]/20 group-hover/feat:border-[#40c4eb]/30 transition-all duration-300">
                      <IconComponent className="w-6 h-6 text-[#40c4eb]" />
                    </div>
                  )}
                  <span class="text-lg font-bold tracking-tight">{feature.text}</span>
                </div>
              );
            })}
          </div>
        </div>
        
        <!-- Right side: Premium CTA Button -->
        <div class="flex items-center justify-center md:justify-end">
          <a 
            href={buttonHref} 
            class="group relative inline-flex items-center justify-center rounded-2xl bg-white text-[#091f41] px-12 py-6 text-xl font-black shadow-[0_20px_40px_rgba(0,0,0,0.3)] hover:bg-[#40c4eb] hover:text-white transition-all duration-500 overflow-hidden"
          >
            <span class="relative z-10">{buttonText}</span>
            <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
          </a>
        </div>
      </div>
    </div>
  </div>
  
</section>

<style>
  [data-animate="fade-up"] {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-animate="fade-up"].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
