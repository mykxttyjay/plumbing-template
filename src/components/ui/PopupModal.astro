---
import { siteConfig, getLocationText } from "@/config/site"

interface Props {
  delay?: number;
  showOnce?: boolean;
  triggerId?: string;
}

const {
  delay = 5000,
  showOnce = true,
  triggerId = "free-scan-trigger",
} = Astro.props;

const phoneRaw = siteConfig.contact.phone;
const phoneFormatted = siteConfig.contact.phoneFormatted;
---

<div
  id="popup-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="popup-title"
  data-delay={delay}
  data-show-once={showOnce}
  data-trigger-id={triggerId}
>
  <div class="relative w-full max-w-md mx-4 bg-card rounded-2xl shadow-2xl overflow-hidden animate-scale-in">

    <!-- Hero image banner -->
    <div class="relative h-48 overflow-hidden">
      <img
        src="/images/photos/ucare-315825d3-1000x666.jpg"
        alt="Professional plumbing team"
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-primary/40 via-primary/60 to-primary/90"></div>

      <!-- Close button -->
      <button
        id="close-popup"
        class="absolute top-3 right-3 z-20 w-8 h-8 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm hover:bg-white/40 text-white transition-all duration-200"
        aria-label="Close popup"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Discount overlay on image -->
      <div class="absolute bottom-0 left-0 right-0 p-6 text-center">
        <div class="inline-block bg-accent text-accent-foreground text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-2">
          New Customer Special
        </div>
        <div class="text-5xl font-black text-white tracking-tight">$50 OFF</div>
        <p class="text-white/80 text-sm mt-1">Any service of $500 or more</p>
      </div>
    </div>

    <!-- Content -->
    <div class="px-6 py-8 space-y-5 text-center">
      <div class="space-y-2">
        <h2 id="popup-title" class="text-xl font-bold text-foreground leading-snug">
          Don't Let Plumbing Problems Wait
        </h2>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-xs mx-auto">
          Book today and save. Our licensed pros handle everything from leaks to full remodels.
        </p>
      </div>

      <!-- Quick stats row -->
      <div class="flex items-center justify-center gap-6 py-3 border-y border-border">
        <div class="text-center">
          <div class="text-lg font-bold text-secondary">20+</div>
          <div class="text-[10px] text-muted-foreground uppercase tracking-wide">Years</div>
        </div>
        <div class="w-px h-8 bg-border"></div>
        <div class="text-center">
          <div class="text-lg font-bold text-secondary">24/7</div>
          <div class="text-[10px] text-muted-foreground uppercase tracking-wide">Service</div>
        </div>
        <div class="w-px h-8 bg-border"></div>
        <div class="text-center">
          <div class="text-lg font-bold text-secondary">5★</div>
          <div class="text-[10px] text-muted-foreground uppercase tracking-wide">Rated</div>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="space-y-3">
        <a
          href="/contact"
          class="block w-full px-6 py-3 bg-accent text-accent-foreground text-center font-semibold text-sm rounded-lg hover:bg-accent/90 transition-colors"
        >
          Claim Your $50 Discount
        </a>
        <a
          href={`tel:${phoneRaw}`}
          class="flex items-center justify-center gap-2 w-full px-6 py-2.5 bg-primary text-primary-foreground text-center font-medium text-sm rounded-lg hover:bg-primary/90 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Now: {phoneFormatted}
        </a>
      </div>

      <!-- Dismiss -->
      <button
        id="close-popup-bottom"
        class="text-xs text-muted-foreground underline hover:text-foreground hover:no-underline transition-colors"
      >
        Maybe later
      </button>
    </div>
  </div>
</div>

<script>
  function showPopup() {
    const popup = document.getElementById("popup-modal");
    if (!popup) return;
    popup.classList.remove("hidden");
    popup.classList.add("flex");
    document.body.style.overflow = "hidden";
    sessionStorage.setItem("popup-shown", "true");
  }

  function closePopup() {
    const popup = document.getElementById("popup-modal");
    if (!popup) return;
    popup.classList.add("hidden");
    popup.classList.remove("flex");
    document.body.style.overflow = "";
  }

  function initPopup() {
    const popup = document.getElementById("popup-modal");
    if (!popup) return;

    const alreadyShown = sessionStorage.getItem("popup-shown") === "true";
    const triggerId = popup.getAttribute("data-trigger-id");

    document.getElementById("close-popup")?.addEventListener("click", closePopup);
    document.getElementById("close-popup-bottom")?.addEventListener("click", closePopup);
    popup.addEventListener("click", (e) => { if (e.target === popup) closePopup(); });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !popup.classList.contains("hidden")) closePopup();
    });

    if (triggerId) {
      document.getElementById(triggerId)?.addEventListener("click", (e) => {
        e.preventDefault();
        showPopup();
      });
    }

    const delay = parseInt(popup.getAttribute("data-delay") || "0") || 0;
    if (delay > 0 && window.innerWidth >= 768 && !alreadyShown) {
      setTimeout(() => { if (window.innerWidth >= 768) showPopup(); }, delay);
    }
  }

  document.addEventListener("astro:page-load", initPopup);
</script>

<style>
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-scale-in {
    animation: scale-in 0.3s ease-out;
  }
</style>
