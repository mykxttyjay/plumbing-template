---
// Floating offer button that triggers the popup modal
// Only visible on desktop (md and up), hides when scrolled to bottom
---

<div id="free-scan-wrapper" class="hidden md:block fixed bottom-8 right-8 z-40">
  <button
    id="free-scan-trigger"
    class="free-scan-btn relative flex items-center bg-[#091f41] text-white font-bold rounded-full shadow-[0_15px_30px_rgba(9,31,65,0.4)] hover:shadow-[0_15px_40px_rgba(64,196,235,0.3)] hover:-translate-y-1 active:scale-[0.95] transition-all duration-500 group overflow-hidden border border-[#40c4eb]/30"
    aria-label="Get $50 off your next service"
  >
    {/* Inner Shimmer Effect */}
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out pointer-events-none"></div>

    {/* Pulsing attention ring */}
    <span class="free-scan-ping absolute inset-0 rounded-full border border-[#40c4eb]/40"></span>

    {/* Icon circle - Layered Design */}
    <div class="relative flex items-center justify-center w-14 h-14 rounded-full flex-shrink-0 bg-gradient-to-br from-[#40c4eb] to-[#23a3ce] shadow-lg z-10 m-1">
      <div class="absolute inset-0 bg-white/30 rounded-full blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      <svg
        class="w-6 h-6 text-white"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
      </svg>
      {/* Dynamic dot */}
      <span class="absolute top-0 right-0 w-3 h-3 rounded-full border-2 border-[#40c4eb] bg-[#ff4d4d] animate-pulse"></span>
    </div>

    {/* Text content - Refined Spacing */}
    <div class="flex flex-col items-start pl-3 pr-8 py-3 leading-tight tracking-tight">
      <span class="text-[10px] font-black uppercase tracking-[0.2em] text-[#40c4eb] mb-1">Special Offer</span>
      <span class="text-base font-black text-white group-hover:text-[#40c4eb] transition-colors duration-300">$50 OFF — Claim Now</span>
    </div>
  </button>
</div>

<style>
  #free-scan-wrapper {
    animation: free-scan-pop 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1s both;
  }

  @keyframes free-scan-pop {
    from {
      opacity: 0;
      transform: scale(0.5) translateY(40px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Pulsing ring for attention */
  .free-scan-ping {
    animation: scan-ping 3s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes scan-ping {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    75%, 100% {
      transform: scale(1.4);
      opacity: 0;
    }
  }

  /* Floating animation */
  .free-scan-btn {
    animation: free-scan-float 4s ease-in-out infinite;
  }

  @keyframes free-scan-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .free-scan-btn:hover {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .free-scan-ping, .free-scan-btn {
      animation: none;
    }
    #free-scan-wrapper {
      animation: none;
      opacity: 1;
    }
  }
</style>
