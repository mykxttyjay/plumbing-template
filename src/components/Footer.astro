---
import { siteConfig } from "@/config/site"

const currentYear = new Date().getFullYear()

const quickLinks = [
  { title: "HOME", href: "/" },
  { title: "ABOUT US", href: "/about" },
  { title: "SPECIALS", href: "/specials-and-offers" },
  { title: "MAINTENANCE PLAN", href: "/maintenance-plan" },
  { title: "FINANCING", href: "/financing" },
  { title: "REVIEWS", href: "/reviews" },
  { title: "CAREERS", href: "/careers" },
  { title: "SERVICES AREAS", href: "/service-areas" },
  { title: "CONTACT US", href: "/contact" },
]

const servicesOffer = [
  { title: "RESIDENTIAL PLUMBING SERVICES", href: "/residential-plumbing" },
  { title: "COMMERCIAL PLUMBING SERVICES", href: "/commercial" },
  { title: "SPECIALTY PLUMBING SERVICES", href: "/specialty" },
  { title: "MAINTENANCE SERVICES", href: "/maintenance" },
]
---

<footer class="bg-brand-primary text-white">
  {/* Main Footer Content */}
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {/* About Us Column */}
      <div>
        <h3 class="text-sm font-bold tracking-wide mb-4 flex items-center gap-2">
          <span class="w-1 h-4 bg-[#A3032B] rounded-full"></span>
          ABOUT US
        </h3>
        <p class="text-sm text-white/70 leading-relaxed mb-6">
          We specialize in residential and commercial plumbing solutions. From repairs and maintenance to advanced leak detection and installations, our team is here to keep your plumbing running smoothly. Contact us today!
        </p>
        <div class="flex gap-2">
          <a
            href="#"
            aria-label="Facebook"
            class="w-8 h-8 rounded bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="#"
            aria-label="X (Twitter)"
            class="w-8 h-8 rounded bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>

      {/* Quick Links Column */}
      <div>
        <h3 class="text-sm font-bold tracking-wide mb-4 flex items-center gap-2">
          <span class="w-1 h-4 bg-[#A3032B] rounded-full"></span>
          QUICK LINKS
        </h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/70 hover:text-highlight transition-colors"
              >
                {link.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Services Offer Column */}
      <div>
        <h3 class="text-sm font-bold tracking-wide mb-4 flex items-center gap-2">
          <span class="w-1 h-4 bg-[#A3032B] rounded-full"></span>
          SERVICES OFFER
        </h3>
        <ul class="space-y-2">
          {servicesOffer.map((service) => (
            <li>
              <a
                href={service.href}
                class="text-sm text-white/70 hover:text-highlight transition-colors"
              >
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact Information Column */}
      <div>
        <h3 class="text-sm font-bold tracking-wide mb-4 flex items-center gap-2">
          <span class="w-1 h-4 bg-[#A3032B] rounded-full"></span>
          CONTACT INFORMATION
        </h3>
        <ul class="space-y-2">
          <li class="text-sm text-white/70">
            PHONE: {siteConfig.contact?.phoneFormatted}
          </li>
          <li class="text-sm text-white/70">
            EMAIL: {siteConfig.contact?.email?.toUpperCase()}
          </li>
          <li class="text-sm text-white/70">
            ADDRESS: {siteConfig.location?.city?.toUpperCase()}, {siteConfig.location?.state?.toUpperCase()}
          </li>
        </ul>
      </div>
    </div>
  </div>

  {/* Copyright Bar */}
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 py-4">
      <p class="text-sm text-white/50 text-center">
        © Copyright {currentYear} {siteConfig.business?.name}
      </p>
    </div>
  </div>
</footer>
