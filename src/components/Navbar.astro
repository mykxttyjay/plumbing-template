---
import { topNavItems, mainNavItems, quickActions } from "@/config/navigation"
import { siteConfig } from "@/config/site"

function getIconSVG(icon: string) {
  const iconMap: Record<string, string> = {
    utensils: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>',
    bath: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>',
    droplet: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path></svg>',
    waves: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
    flame: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"></path></svg>',
    pipette: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path></svg>',
    building: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>',
    zap: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>',
    shield: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>',
    search: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>',
    alert: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
    filter: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>',
    leaf: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>',
    clipboard: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>',
    settings: '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>',
  };
  return iconMap[icon] || iconMap.settings;
}
---

<header class="sticky top-0 z-50 w-full mb-12" id="main-navbar">
  <!-- Top Bar - Dark Blue -->
  <div class="hidden lg:block bg-brand-primary text-white">
    <div class="container mx-auto px-4">
      <div class="flex h-9 items-center justify-between gap-6 text-sm">
        <!-- Left: Contact Info with Icons -->
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span>{siteConfig.contact?.phoneFormatted}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>{siteConfig.contact?.email}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>{siteConfig.location?.city}, {siteConfig.location?.state}</span>
          </div>
        </div>
        
        <!-- Right: Nav Links -->
        <div class="flex items-center gap-6">
          {topNavItems.map((item) => (
            item.children ? (
              <div class="relative top-nav-dropdown" data-dropdown>
                <a href={item.href} class="flex items-center gap-1 text-sm font-medium text-white hover:text-highlight transition-colors duration-200 py-2 cursor-pointer relative after:absolute after:bottom-0 after:left-0 after:w-0 hover:after:w-full after:h-[3px] after:bg-highlight after:transition-all after:duration-300 after:rounded-full">
                  <span>{item.title}</span>
                  <svg class="h-3 w-3 transition-transform dropdown-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </a>
                <div class="dropdown-menu hidden absolute top-full right-0 mt-2 bg-brand-secondary rounded-lg shadow-xl py-3 min-w-[220px] border-2 border-white/20 z-[70]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-5 py-2.5 text-sm font-medium text-white hover:text-highlight hover:bg-white/10 transition-colors duration-200"
                    >
                      {child.title}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a href={item.href} class="text-sm font-medium text-white hover:text-highlight transition-colors duration-200 py-2 relative after:absolute after:bottom-0 after:left-0 after:w-0 hover:after:w-full after:h-[3px] after:bg-highlight after:transition-all after:duration-300 after:rounded-full">
                {item.title}
              </a>
            )
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Middle Section - White with Logo, Quick Actions, Phone -->
  <div class="bg-white">
    <div class="container mx-auto px-4 flex h-20 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img 
          src={siteConfig.logo?.src} 
          alt={siteConfig.logo?.alt || "Logo"} 
          class="h-14 w-14 object-contain"
          width="56"
          height="56"
          decoding="async"
          loading="eager"
        />
        <div class="hidden sm:block">
          <span class="font-bold text-lg" style="color: #091f41">{siteConfig.business?.name}</span>
        </div>
      </a>

      <!-- Quick Actions - Desktop -->
      <div class="hidden lg:flex items-center gap-12">
        {quickActions.map((action) => (
          <a 
            href={action.href}
            class="group flex items-center gap-3 transition-all duration-200 hover:-translate-y-0.5"
          >
            <div class="w-10 h-10 rounded-full bg-brand-secondary flex items-center justify-center transition-all duration-200 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-highlight/40">
              {action.icon === "settings" ? (
                <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              ) : (
                <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              )}
            </div>
            <span class="font-semibold transition-colors duration-200" style="color: #091f41">{action.title}</span>
          </a>
        ))}
      </div>

      <!-- Phone Number and CTA - Desktop -->
      <div class="hidden lg:flex items-center gap-6">
        <a href={`tel:${siteConfig.contact?.phone}`} class="group flex items-center gap-3 hover:-translate-y-0.5 transition-transform duration-200">
          <div class="w-10 h-10 rounded-full bg-brand-secondary flex items-center justify-center transition-all duration-200 group-hover:bg-highlight group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-highlight/30">
            <span class="text-white text-xs font-bold group-hover:text-brand-primary transition-colors duration-200">24/7</span>
          </div>
          <div class="text-right">
            <p class="text-xs uppercase tracking-wide" style="color: #091f41">Call Us Now</p>
            <span class="font-bold text-lg group-hover:text-highlight transition-colors duration-200" style="color: #091f41">
              {siteConfig.contact?.phoneFormatted}
            </span>
          </div>
        </a>

        <!-- GET A QUOTE Button -->
        <a href="/contact" class="bg-accent hover:bg-accent/90 text-white font-semibold px-6 py-2 rounded-full transition-colors duration-200">
          GET A QUOTE
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2" aria-label="Open menu">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Bottom Nav Bar - Blue -->
  <div class="hidden lg:block absolute w-full top-full left-0 z-[60]" id="bottom-nav">
    <div class="container mx-auto px-4 mt-2">
      <div class="bg-brand-secondary rounded-2xl flex h-14 items-center justify-center shadow-md">
        <nav class="flex items-center h-full">
          {mainNavItems.map((item) => (
            <div class="relative h-full flex items-center service-nav-item" data-mega-menu>
              <a href={item.href} class="flex items-center gap-1 text-base font-semibold text-white hover:text-white hover:bg-white/10 transition-all duration-200 px-4 h-full cursor-pointer relative after:absolute after:bottom-0 after:left-2 after:right-2 after:h-[3px] after:bg-white after:rounded-t after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300 after:origin-center">
                <span>{item.title}</span>
                <svg class="h-3 w-3 transition-transform duration-200 mega-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </a>
              <div class="mega-menu hidden fixed left-0 right-0 z-[100] mt-2">
                <div class="container mx-auto px-4">
                  <div class="bg-white shadow-2xl rounded-2xl px-8 py-10 border border-gray-100">
                    <div class="grid grid-cols-6 gap-x-8 gap-y-6">
                      {item.categories.map((category) => (
                        <div class="min-w-0">
                          <div class="flex items-center gap-2 mb-4 pb-2 border-b-2 border-brand-secondary/30">
                            <span class="text-brand-secondary flex-shrink-0" set:html={getIconSVG(category.icon)}></span>
                            <h3 class="text-xs font-bold text-brand-primary uppercase tracking-wide whitespace-nowrap">
                              {category.href ? (
                                <a href={category.href} class="hover:text-highlight transition-colors duration-200">
                                  {category.title}
                                </a>
                              ) : (
                                category.title
                              )}
                            </h3>
                          </div>
                          <ul class="space-y-2">
                            {category.items.map((service) => (
                              <li>
                                <a
                                  href={service.href}
                                  class="text-sm text-gray-700 hover:text-brand-secondary hover:bg-brand-secondary/5 hover:pl-2 transition-all duration-200 block leading-snug py-1.5 rounded"
                                >
                                  {service.title}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </nav>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[100] hidden">
  <div class="absolute inset-0 bg-black/50" id="mobile-menu-backdrop"></div>
  <div class="absolute right-0 top-0 bottom-0 w-full sm:w-[400px] bg-white shadow-xl overflow-y-auto mobile-menu-content transform translate-x-full transition-transform duration-300">
    <div class="border-b p-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold">Menu</h2>
      <button id="mobile-menu-close" class="p-2" aria-label="Close menu">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- Mobile menu content will be populated by JavaScript -->
    <div id="mobile-menu-content">
      <!-- Phone CTA -->
      <div class="bg-brand-primary p-4">
        <a href={`tel:${siteConfig.contact?.phone}`} class="flex items-center justify-center gap-2 text-white">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          <span class="font-bold text-lg">{siteConfig.contact?.phoneFormatted}</span>
        </a>
      </div>

      <!-- Quick Actions -->
      <div class="grid grid-cols-2 gap-2 p-4 bg-gray-50">
        {quickActions.map((action) => (
          <a href={action.href} class="flex items-center gap-2 p-3 bg-white rounded-lg shadow-sm">
            <div class="w-8 h-8 rounded-full bg-brand-secondary flex items-center justify-center">
              {action.icon === "settings" ? (
                <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              ) : (
                <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              )}
            </div>
            <span class="text-sm font-medium text-gray-700">{action.title}</span>
          </a>
        ))}
      </div>

      <!-- CTA Button -->
      <div class="p-4">
        <a href="/contact" class="block w-full bg-accent hover:bg-accent/90 text-white font-semibold py-4 rounded-full text-base text-center">
          GET A QUOTE
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function initDropdowns() {
    // Calculate navbar height for mega menu positioning
    const navbar = document.getElementById('main-navbar');
    let navbarHeight = navbar?.offsetHeight || 0;
    
    const bottomNav = document.getElementById('bottom-nav');
    if (bottomNav && window.getComputedStyle(bottomNav).display !== 'none') {
      const rect = bottomNav.getBoundingClientRect();
      navbarHeight = rect.bottom;
    }
    // Top nav dropdowns
    document.querySelectorAll('[data-dropdown]').forEach(dropdown => {
      const menu = dropdown.querySelector('.dropdown-menu');
      const chevron = dropdown.querySelector('.dropdown-chevron');
      let timeout: NodeJS.Timeout | null = null;
      
      const showMenu = () => {
        if (timeout) {
          clearTimeout(timeout);
          timeout = null;
        }
        menu?.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
      };
      
      const hideMenu = () => {
        timeout = setTimeout(() => {
          menu?.classList.add('hidden');
          chevron?.classList.remove('rotate-180');
        }, 150);
      };
      
      dropdown.addEventListener('mouseenter', showMenu);
      dropdown.addEventListener('mouseleave', hideMenu);
      menu?.addEventListener('mouseenter', showMenu);
      menu?.addEventListener('mouseleave', hideMenu);
    });

    // Mega menu dropdowns - hide all other menus when one is shown
    const allMegaMenus = document.querySelectorAll('[data-mega-menu]');
    
    allMegaMenus.forEach(item => {
      const menu = item.querySelector('.mega-menu') as HTMLElement;
      const chevron = item.querySelector('.mega-chevron');
      let timeout: NodeJS.Timeout | null = null;
      
      // Set the top position dynamically
      if (menu) {
        menu.style.top = `${navbarHeight}px`;
      }
      
      const hideAllMenus = () => {
        allMegaMenus.forEach(otherItem => {
          const otherMenu = otherItem.querySelector('.mega-menu');
          const otherChevron = otherItem.querySelector('.mega-chevron');
          otherMenu?.classList.add('hidden');
          otherChevron?.classList.remove('rotate-180');
        });
      };
      
      const showMenu = () => {
        if (timeout) {
          clearTimeout(timeout);
          timeout = null;
        }
        hideAllMenus(); // Hide all other menus first
        menu?.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
      };
      
      const hideMenu = () => {
        timeout = setTimeout(() => {
          menu?.classList.add('hidden');
          chevron?.classList.remove('rotate-180');
        }, 150);
      };
      
      item.addEventListener('mouseenter', showMenu);
      item.addEventListener('mouseleave', hideMenu);
      menu?.addEventListener('mouseenter', showMenu);
      menu?.addEventListener('mouseleave', hideMenu);
    });
  }

  function initMobileMenu() {
    // Mobile menu
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
    const mobileMenuContent = mobileMenu?.querySelector('.mobile-menu-content');

    const openMobileMenu = () => {
      mobileMenu?.classList.remove('hidden');
      setTimeout(() => {
        mobileMenuContent?.classList.remove('translate-x-full');
      }, 10);
    };

    const closeMobileMenu = () => {
      mobileMenuContent?.classList.add('translate-x-full');
      setTimeout(() => {
        mobileMenu?.classList.add('hidden');
      }, 300);
    };

    mobileMenuBtn?.addEventListener('click', openMobileMenu);
    mobileMenuClose?.addEventListener('click', closeMobileMenu);
    mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);
  }

  // Initialize on first load
  initDropdowns();
  initMobileMenu();

  // Re-initialize after Astro page transitions
  document.addEventListener('astro:page-load', () => {
    initDropdowns();
    initMobileMenu();
  });
</script>
