---
import { getEntry } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import DynamicSection from "@/components/DynamicSection.astro"
import { getLocationText } from "@/config/site"

const page = await getEntry("pages", "index")
if (!page) throw new Error("index.json not found in src/content/pages/")
const { meta, sections } = page.data
---

<BaseLayout
  title={getLocationText(meta.title)}
  description={getLocationText(meta.description || "")}
  keywords={meta.keywords}
  ogImage={meta.ogImage}
>
  {sections.map((section) => (
    <DynamicSection component={section.component} props={section.props} />
  ))}
</BaseLayout>
