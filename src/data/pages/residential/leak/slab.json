        "faqs": [
          {
            "question": "What is a slab leak?",
            "answer": "A slab leak occurs when water or sewer pipes running beneath your concrete foundation develop a crack or hole. This can lead to foundation damage, mold growth, and increased water bills."
          },
          {
            "question": "What are the signs of a slab leak?",
            "answer": "Common signs include warm spots on the floor, the sound of running water when all fixtures are off, cracks in walls or flooring, unexplained high water bills, and damp or wet carpet areas."
          },
          {
            "question": "How do you repair a slab leak?",
            "answer": "Repair methods include spot repair through the slab, rerouting pipes above or around the slab, or epoxy pipe lining. We recommend the best approach based on the leak location and severity."
          }
        ]
