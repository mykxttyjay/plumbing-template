        "faqs": [
          {
            "question": "What does a dishwasher plumbing check include?",
            "answer": "We inspect the water supply line, drain hose, and connections for leaks or wear. We also check the air gap or high loop, test water pressure, and ensure proper drainage to prevent backflow."
          },
          {
            "question": "How often should dishwasher plumbing be checked?",
            "answer": "We recommend an annual inspection as part of your regular plumbing maintenance. Dishwashers older than 5 years or those showing signs of leaking should be checked more frequently."
          },
          {
            "question": "What are signs of dishwasher plumbing problems?",
            "answer": "Watch for water pooling under or around the dishwasher, slow drainage after cycles, unusual noises during operation, water spots or stains on nearby cabinets, and musty odors indicating hidden moisture."
          }
        ]
      }
